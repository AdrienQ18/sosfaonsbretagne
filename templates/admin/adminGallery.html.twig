{% extends 'base.html.twig' %}

{% block title %}
    Gestion de la galerie | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Interface d'administration de la galerie photo de SOS Faons Bretagne.
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <section class="admin-gallery-page ui-page">

        <div class="admin-gallery-container ui-container">

            <header class="admin-gallery-header ui-header">

                <h1>Gestion de la galerie</h1>

                <p>
                    Ajouter ou supprimer les photos affichées dans la galerie du site.
                </p>

            </header>

            <div class="admin-gallery-upload-card ui-card">

                <h2>Ajouter une image</h2>

                <form
                    method="post"
                    enctype="multipart/form-data"
                    action="{{ path('admin_gallery_add') }}"
                    class="admin-gallery-upload-form"
                >

                    <input
                        type="file"
                        name="gallery_image"
                        accept=".jpg,.jpeg,.png,.webp"
                        required
                    >

                    <button
                        type="submit"
                        class="admin-gallery-upload-button ui-button ui-button--primary"
                    >
                        Ajouter à la galerie
                    </button>

                </form>

            </div>

            <div class="admin-gallery-grid ui-grid ui-grid--3">

                {% for image in images %}

                    <article class="admin-gallery-card ui-card">

                        <img
                            src="{{ asset('images/gallery/' ~ image) }}"
                            alt="{{ image }}"
                            class="admin-gallery-image"
                            loading="lazy"
                        >

                        <div class="admin-gallery-card-footer">

                        <span class="admin-gallery-filename">
                            {{ image }}
                        </span>

                            <form
                                id="delete-gallery-{{ loop.index }}"
                                method="post"
                                action="{{ path('admin_gallery_delete', { filename: image }) }}"
                            >

                                <input
                                    type="hidden"
                                    name="_token"
                                    value="{{ csrf_token('delete_gallery_' ~ image) }}"
                                >

                                <button
                                    type="submit"
                                    form="delete-gallery-{{ loop.index }}"
                                    formmethod="post"
                                    formaction="{{ path('admin_gallery_delete', { filename: image }) }}"
                                    class="admin-gallery-delete-button ui-button ui-button--delete ui-button--full"
                                    onclick="return confirm('Supprimer cette image ?')"
                                >
                                    Supprimer
                                </button>

                            </form>

                        </div>

                    </article>

                {% else %}

                    <div class="admin-gallery-empty ui-empty-state">

                        <h2>Aucune image</h2>

                        <p>
                            La galerie est actuellement vide.
                        </p>

                    </div>

                {% endfor %}

            </div>

        </div>

    </section>

{% endblock %}
