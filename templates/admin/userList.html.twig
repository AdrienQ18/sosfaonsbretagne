{% extends 'base.html.twig' %}

{% block title %}
    Administration des utilisateurs | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Interface privée de gestion des utilisateurs SOS Faons Bretagne.
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <section class="admin-user-page ui-page">

        <div class="admin-user-container ui-container">

            <header class="admin-user-header ui-admin-header ui-header">

                <h1>Liste des utilisateurs</h1>

                <div class="admin-user-count ui-counter ui-card">
                    <span>Nombre d'utilisateurs</span>
                    <strong>{{ users.getTotalItemCount }}</strong>
                </div>

            </header>

            <div class="admin-user-filter-card ui-card">

                {{ form_start(filterForm, {
                    method: 'GET',
                    attr: {
                        id: 'user-filter-form',
                        class: 'admin-user-filter-form',
                        'data-reset-url': path('admin_userList')
                    }
                }) }}

                <div class="admin-user-filter-grid ui-form-grid">

                    <div class="admin-user-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.search) }}
                        {{ form_widget(filterForm.search) }}
                    </div>

                    <div class="admin-user-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.actif) }}
                        {{ form_widget(filterForm.actif) }}
                    </div>

                    <div class="admin-user-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.role) }}
                        {{ form_widget(filterForm.role) }}
                    </div>

                    <div class="admin-user-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.right) }}
                        {{ form_widget(filterForm.right) }}
                    </div>

                    <div class="admin-user-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.dateStart) }}
                        {{ form_widget(filterForm.dateStart) }}
                    </div>

                    <div class="admin-user-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.dateEnd) }}
                        {{ form_widget(filterForm.dateEnd) }}
                    </div>

                </div>

                <div class="admin-user-filter-actions ui-actions ui-actions--end">

                    <button
                        type="button"
                        id="reset-user-filters"
                        class="admin-user-reset-button ui-button ui-button--secondary ui-button--filter"
                    >
                        Réinitialiser
                    </button>

                </div>

                {{ form_end(filterForm) }}

            </div>

            <div class="admin-user-card ui-card">

                <div class="admin-user-table-wrapper ui-table-wrapper">

                    <table class="admin-user-table ui-table ui-table--1200">

                        <caption class="admin-user-sr-only ui-sr-only">
                            Liste des utilisateurs enregistrés
                        </caption>

                        <thead>
                        <tr>
                            <th scope="col">Nom</th>
                            <th scope="col">Prénom</th>
                            <th scope="col">Email</th>
                            <th scope="col">Téléphone</th>
                            <th scope="col">Adresse</th>
                            <th scope="col">Ville</th>
                            <th scope="col">Code postal</th>
                            <th scope="col">Création</th>
                            <th scope="col">Statut</th>
                            <th scope="col">Rôle</th>
                            <th scope="col">Droit</th>
                            <th scope="col">Action</th>
                        </tr>
                        </thead>

                        <tbody>

                        {% for user in users %}

                            <tr>
                                <td>{{ user.lastname ?: '-' }}</td>
                                <td>{{ user.firstname ?: '-' }}</td>

                                <td>
                                    <a href="mailto:{{ user.email }}">
                                        {{ user.email }}
                                    </a>
                                </td>

                                <td>{{ user.phone ?: '-' }}</td>
                                <td>{{ user.address ?: '-' }}</td>
                                <td>{{ user.city ?: '-' }}</td>
                                <td>{{ user.zipcode ?: '-' }}</td>

                                <td>
                                    {{ user.creationDate ? user.creationDate|date('d/m/Y') : '-' }}
                                </td>

                                <td>
                                    {% if user.actif %}
                                        <span class="admin-user-status admin-user-status--active ui-status ui-status--success">
                                            Actif
                                        </span>
                                    {% else %}
                                        <span class="admin-user-status admin-user-status--inactive ui-status ui-status--danger">
                                            Inactif
                                        </span>
                                    {% endif %}
                                </td>

                                <td>
                                    {{ user.userRole.name ?? 'Non défini' }}
                                </td>

                                <td>
                                    {% if 'ROLE_ADMIN' in user.roles %}
                                        <span class="admin-user-badge admin-user-badge--admin ui-status ui-status--info">
                                            Administrateur
                                        </span>
                                    {% else %}
                                        <span class="admin-user-badge ui-status">
                                            Utilisateur
                                        </span>
                                    {% endif %}
                                </td>

                                <td>
                                    <a
                                        href="{{ path('admin_modify', { id: user.id }) }}"
                                        class="admin-user-edit-button ui-button ui-button--primary"
                                        aria-label="Modifier l'utilisateur {{ user.firstname }} {{ user.lastname }}"
                                        onclick="return confirm('Êtes-vous sûr de vouloir modifier cet utilisateur ?');"
                                    >
                                        Modifier
                                    </a>
                                </td>
                            </tr>

                        {% else %}

                            <tr>
                                <td colspan="12" class="admin-user-empty">
                                    Aucun utilisateur trouvé.
                                </td>
                            </tr>

                        {% endfor %}

                        </tbody>

                    </table>

                </div>

            </div>

            <div class="admin-user-pagination ui-pagination">
                {{ knp_pagination_render(users) }}
            </div>

        </div>

    </section>

{% endblock %}
