{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Nouveau signalement
{% endblock %}

{% block email_header %}
    <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3;">
        Nouveau signalement
    </h1>

    <p style="margin:8px 0 0 0; color:#ffffff;">
        SOS Faons Bretagne
    </p>
{% endblock %}

{% block email_content %}

    <div
        style="
            background-color:#f4efe8;
            border-left:4px solid #6e8e64;
            padding:16px;
            margin-bottom:24px;
            color:#2b2b2b;
        "
    >
        Un nouveau signalement a été enregistré sur le site.
    </div>

    <h2
        style="
            color:#1b4a3a;
            font-size:20px;
            margin:0 0 16px 0;
        "
    >
        Informations du signalement
    </h2>

    <table
        width="100%"
        cellpadding="0"
        cellspacing="0"
        border="0"
        style="
            border-collapse:collapse;
            margin-bottom:30px;
        "
    >

        <tr>
            <td
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    font-weight:bold;
                    width:180px;
                    color:#1b4a3a;
                "
            >
                Type
            </td>

            <td
                style="
                    border:1px solid #ddd5cc;
                    padding:12px;
                "
            >
                {{ alert.type }}
            </td>
        </tr>

        <tr>
            <td
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    font-weight:bold;
                    color:#1b4a3a;
                "
            >
                Type de culture
            </td>

            <td
                style="
                    border:1px solid #ddd5cc;
                    padding:12px;
                "
            >
                {{ alert.cultureType }}
            </td>
        </tr>

        <tr>
            <td
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    font-weight:bold;
                    color:#1b4a3a;
                "
            >
                Date du signalement
            </td>

            <td
                style="
                    border:1px solid #ddd5cc;
                    padding:12px;
                "
            >
                {{ alert.creationDate|date('d/m/Y H:i') }}
            </td>
        </tr>

        {% if alert.interventionDate %}
            <tr>
                <td
                    style="
                        background:#f4efe8;
                        border:1px solid #ddd5cc;
                        padding:12px;
                        font-weight:bold;
                        color:#1b4a3a;
                    "
                >
                    Date d'intervention
                </td>

                <td
                    style="
                        border:1px solid #ddd5cc;
                        padding:12px;
                    "
                >
                    {{ alert.interventionDate|date('d/m/Y H:i') }}
                </td>
            </tr>
        {% endif %}

        {% if alert.localisation %}
            <tr>
                <td
                    style="
                        background:#f4efe8;
                        border:1px solid #ddd5cc;
                        padding:12px;
                        font-weight:bold;
                        color:#1b4a3a;
                    "
                >
                    Localisation
                </td>

                <td
                    style="
                        border:1px solid #ddd5cc;
                        padding:12px;
                    "
                >
                    {{ alert.localisation }}
                </td>
            </tr>
        {% endif %}

        {% if alert.surface %}
            <tr>
                <td
                    style="
                        background:#f4efe8;
                        border:1px solid #ddd5cc;
                        padding:12px;
                        font-weight:bold;
                        color:#1b4a3a;
                    "
                >
                    Surface
                </td>

                <td
                    style="
                        border:1px solid #ddd5cc;
                        padding:12px;
                    "
                >
                    {{ alert.surface }} m²
                </td>
            </tr>
        {% endif %}

    </table>

    <h2
        style="
            color:#1b4a3a;
            font-size:20px;
            margin:0 0 16px 0;
        "
    >
        Description
    </h2>

    <div
        style="
            background-color:#f4efe8;
            border-left:4px solid #6e8e64;
            padding:16px;
            color:#2b2b2b;
            line-height:1.7;
        "
    >
        {{ alert.description|nl2br }}
    </div>

{% endblock %}

{% block email_footer %}
    Notification automatique SOS Faons Bretagne.<br>
    Merci de ne pas répondre directement à cet email.
{% endblock %}
