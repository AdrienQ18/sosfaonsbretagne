{% extends 'base.html.twig' %}

{% block title %}
    Disponibilités | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Administration des disponibilités possibles sur le site de SOS Faons Bretagne.
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <section class="availability-page admin-meta-page ui-page">
        <div class="availability-container admin-meta-container ui-container">

            <div class="availability-header admin-meta-header ui-header">
                <h1>Gestion des disponibilités</h1>
                <p>Ajoutez, modifiez ou supprimez les disponibilités proposées aux bénévoles.</p>
            </div>

            <div class="availability-grid admin-meta-grid">

                <section class="availability-card availability-list-card admin-meta-card ui-card">
                    <div class="availability-card-header admin-meta-card-header">
                        <h2>Disponibilités existantes</h2>
                        <span>{{ availabilityList|length }} élément(s)</span>
                    </div>

                    <div class="availability-table-wrapper admin-meta-table-wrapper">
                        <table class="availability-table admin-meta-table">
                            <thead>
                            <tr>
                                <th>Disponibilité</th>
                                <th>Actions</th>
                            </tr>
                            </thead>

                            <tbody>
                            {% for availability in availabilityList %}
                                <tr>
                                    <td>
                                        <span class="availability-badge admin-meta-badge">
                                            {{ availability.label }}
                                        </span>
                                    </td>

                                    <td>
                                        <div class="availability-actions admin-meta-actions">
                                            <a
                                                href="{{ path('admin_availability_update', { id: availability.id }) }}"
                                                class="availability-edit-link admin-meta-edit-link ui-button ui-button--primary"
                                                aria-label="Modifier la disponibilité {{ availability.label }}"
                                            >
                                                Modifier
                                            </a>

                                            <form
                                                method="post"
                                                action="{{ path('admin_availability_delete', { id: availability.id }) }}"
                                                onsubmit="return confirm('Voulez-vous vraiment supprimer cette disponibilité ?');"
                                            >
                                                <input
                                                    type="hidden"
                                                    name="_token"
                                                    value="{{ csrf_token('delete_availability_' ~ availability.id) }}"
                                                >

                                                <button
                                                    type="submit"
                                                    class="availability-delete-button admin-meta-delete-button ui-button ui-button--delete"
                                                    aria-label="Supprimer la disponibilité {{ availability.label }}"
                                                >
                                                    Supprimer
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="2" class="availability-empty admin-meta-empty">
                                        Aucune disponibilité enregistrée.
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </section>

                <section class="availability-card availability-form-card admin-meta-card admin-meta-form-card ui-card">
                    <h2>
                        {% if isEdit %}
                            Modifier une disponibilité
                        {% else %}
                            Ajouter une disponibilité
                        {% endif %}
                    </h2>

                    <p>
                        {% if isEdit %}
                            Modifiez le libellé de cette disponibilité.
                        {% else %}
                            Créez une nouvelle disponibilité pour les bénévoles.
                        {% endif %}
                    </p>

                    {{ form_start(formAvailability, {
                        attr: {
                            novalidate: 'novalidate',
                            class: 'availability-form admin-meta-form'
                        }
                    }) }}

                    <div class="availability-form-group ui-field">
                        {{ form_label(formAvailability.label, 'Libellé') }}
                        {{ form_widget(formAvailability.label, {
                            attr: {
                                placeholder: 'Ex : matin, soir, week-end...',
                                autocomplete: 'off'
                            }
                        }) }}
                        {{ form_errors(formAvailability.label) }}
                    </div>

                    <button type="submit" class="availability-submit-button admin-meta-submit-button ui-button ui-button--primary">
                        {% if isEdit %}
                            Modifier la disponibilité
                        {% else %}
                            Ajouter la disponibilité
                        {% endif %}
                    </button>

                    {{ form_end(formAvailability) }}
                </section>

            </div>

        </div>
    </section>

{% endblock %}
