<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SOS Faons Bretagne | Sauvetage des faons et protection de la biodiversité{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}SOS Faons Bretagne intervient aux côtés des agriculteurs pour repérer et sauver les faons avant les fauches grâce à des drones thermiques. Ensemble, protégeons la biodiversité bretonne.{% endblock %}">
    {% block canonical %}<link rel="canonical" href="{{ app.request.uri }}">{% endblock %}
    {% block robots %}<meta name="robots" content="index, follow">{% endblock %}
    <meta property="og:title" content="{% block og_title %}SOS Faons Bretagne | Sauvetage des faons et protection de la biodiversité{% endblock %}">
    <meta property="og:description" content="{% block og_description %}SOS Faons Bretagne intervient aux côtés des agriculteurs pour repérer et sauver les faons avant les fauches grâce à des drones thermiques. Ensemble, protégeons la biodiversité bretonne.{% endblock %}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:image" content="{{ absolute_url(asset('images/LogoSOSFaonsBretagne.svg')) }}">
    <meta property="og:site_name" content="SOS Faons Bretagne">
    <meta property="og:locale" content="fr_FR">
    <link rel="icon" href="{{ asset('images/icones/logo/LogoSOSFaonsBretagne-favicon.ico') }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('images/icones/logo/LogoSOSFaonsBretagne-apple-touch-icon.png') }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('images/icones/logo/LogoSOSFaonsBretagne-favicon-32x32.png') }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('images/icones/logo/LogoSOSFaonsBretagne-favicon-16x16.png') }}">
    <link rel="icon" href="{{ asset('images/LogoSOSFaonsBretagne.svg') }}" type="image/svg+xml">
    <link rel="manifest" href="{{ asset('images/icones/logo/site.webmanifest') }}">
    {% block stylesheets %}{% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body data-route="{{ app.request.attributes.get('_route') }}">
<div class="container">
    <header>
        {% include 'views/nav/nav.html.twig' %}
    </header>
    <main>
        {# read and display all flash messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </main>
    <footer>
        {% include 'views/footer/footer.html.twig' %}
    </footer>
</div>
<script>
    console.log('BASE TWIG OK');
</script>
</body>
</html>
