{% extends 'base.html.twig' %}

{% block title %}
    Erreur {{ status_code }} | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Une erreur est survenue sur le site SOS Faons Bretagne.
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <section class="error-page">
        <div class="error-container">

            <div class="error-card ui-card">

                <span class="error-code">
                    Erreur {{ status_code }}
                </span>

                <h1>
                    Oups, une erreur s’est produite.
                </h1>

                <p class="error-status">
                    Le serveur a renvoyé l’erreur :
                    <strong>{{ status_code }} {{ status_text }}</strong>
                </p>

                {% if app.environment == 'dev' and exception is defined and exception.message is not empty %}
                    <div class="error-debug">
                        {{ exception.message }}
                    </div>
                {% endif %}

                <p>
                    Quelque chose ne fonctionne pas correctement.
                    Vous pouvez réessayer dans quelques instants ou nous contacter à
                    <a href="mailto:contact@sosfaonsbretagne.fr">
                        contact@sosfaonsbretagne.fr
                    </a>
                    en nous indiquant ce que vous faisiez lorsque cette erreur est apparue.
                </p>

                <a href="{{ path('main_home') }}" class="ui-button ui-button--primary ui-button--wide ui-button--padded-large ui-button--caps">
                    Retour à l’accueil
                </a>

            </div>

        </div>
    </section>

{% endblock %}
