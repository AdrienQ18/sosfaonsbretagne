<div class="carousel">
    <h1 class="carousel">Nos partenaires :</h1>
    <div class="carousel-inner">
        {% set images = [
            'slide1.jpg',
            'slide2.svg',
            'slide3.webp',
            'slide4.webp',
            'slide5.png',
            'slide6.png',
            'slide7.jpg',
            'slide8.svg',
            'slide9.jpg',
            'slide10.svg',
            'slide11.png',
            'slide12.png']  %}
        {% for image in images %}
            <div class="carousel-item">
                <img src="{{ asset('images/partenaire/' ~ image) }}" alt="Slide">
            </div>
        {% endfor %}
    </div>
    <button class="carousel-control prev">&#10094;</button>
    <button class="carousel-control next">&#10095;</button>
</div>
