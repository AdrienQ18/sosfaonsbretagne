{% extends 'base.html.twig' %}

{% block body %}
    <h1>Administration des donations</h1>
    <div>
        <strong>Total des dons validés :</strong>
        {{ totalValidatedAmount|number_format(2, ',', ' ') }} €
    </div>
    {{ form_start(filterForm, {
        attr: {
            id: 'donation-filter-form'
        }
    }) }}

    {{ form_row(filterForm.search) }}
    {{ form_row(filterForm.donorType) }}
    {{ form_row(filterForm.status) }}
    {{ form_row(filterForm.dateStart) }}
    {{ form_row(filterForm.dateEnd) }}
    {{ form_row(filterForm.email) }}
    {{ form_row(filterForm.companySiret) }}
    <button
        type="button"
        id="reset-filters"
    >
        Réinitialiser
    </button>
    <a href="{{ path('admin_donation_download_pdfs', app.request.query.all) }}">
        Télécharger les PDF de la recherche
    </a>
    {{ form_end(filterForm) }}
    <table>
        <thead>
        <tr>
            <th>Type</th>
            <th>Donateur / Contact</th>
            <th>Email</th>
            <th>Adresse</th>
            <th>Montant</th>
            <th>Numéro du reçu fiscal</th>
            <th>Statut</th>
            <th>Date</th>
            <th>Reçu fiscal</th>
            <th>Entreprise</th>
            <th>SIRET</th>
        </tr>
        </thead>

        <tbody>
        {% for donation in donations %}
            <tr>
                <td>
                    {% if donation.donorType.value == 'entreprise' %}
                        Entreprise
                    {% else %}
                        Particulier
                    {% endif %}
                </td>

                <td>{{ donation.firstname }} {{ donation.lastname }}</td>

                <td>{{ donation.email }}</td>

                <td>
                    {{ donation.address }}<br>
                    {{ donation.zipcode }} {{ donation.city }}
                </td>

                <td>{{ donation.amount }} €</td>

                <td>
                    {{ donation.fiscalReceiptNumber ?? 'Non généré' }}
                </td>

                <td>{{ donation.status.value }}</td>

                <td>{{ donation.donationDate|date('d/m/Y H:i') }}</td>

                <td>
                    {% if donation.receiptPdfPath %}
                        <a href="{{ path('admin_donation_pdf', { id: donation.id }) }}" target="_blank">
                            Voir le PDF
                        </a>
                    {% else %}
                        Aucun PDF
                    {% endif %}
                </td>

                <td>
                    {{ donation.companyName ?? '-' }}
                </td>

                <td>
                    {{ donation.companySiret ?? '-' }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="12">Aucune donation trouvée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <div class="pagination">
        {{ knp_pagination_render(donations) }}
    </div>
{% endblock %}

{% block extraJs %}
    {{ parent() }}

    <script>
        const filterForm = document.querySelector('#donation-filter-form');

        document.querySelector('#reset-filters')
            .addEventListener('click', () => {

                window.location.href =
                    "{{ path('admin_donation') }}";

            });

        filterForm.querySelectorAll('select').forEach(field => {

            field.addEventListener('change', () => {
                filterForm.submit();
            });

        });

        filterForm.querySelectorAll('input[type="date"]').forEach(field => {
            field.addEventListener('change', () => {
                filterForm.submit();
            });
        });

        let timeout;

        filterForm.querySelectorAll('input[type="text"]').forEach(field => {

            field.addEventListener('input', () => {

                clearTimeout(timeout);

                timeout = setTimeout(() => {
                    filterForm.submit();
                }, 600);

            });

        });
    </script>
{% endblock %}


