{% extends 'base.html.twig' %}
{% block title %}
    Administration des donations | SOS Faons Bretagne
{% endblock %}
{% block meta_description %}
    Interface privée de suivi des donations et reçus fiscaux SOS Faons Bretagne.
{% endblock %}
{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}
{% block canonical %}{% endblock %}
{% block body %}
    <section class="admin-donation-page ui-page">
        <div class="admin-donation-container ui-container">
            <header class="admin-donation-header ui-header">
                <h1>Administration des donations</h1>
                <div class="admin-donation-total ui-counter ui-card">
                    <span>Total des dons validés</span>
                    <strong>{{ totalValidatedAmount|number_format(2, ',', ' ') }} €</strong>
                </div>
            </header>
            <div class="admin-donation-card admin-donation-filter-card ui-card">
                {{ form_start(filterForm, {attr: {id: 'donation-filter-form',class: 'admin-donation-filter-form','data-reset-url': path('admin_donation')}}) }}
                <div class="admin-donation-filter-grid ui-form-grid">
                    <div class="admin-donation-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.search) }}
                        {{ form_widget(filterForm.search) }}
                    </div>
                    <div class="admin-donation-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.donorType) }}
                        {{ form_widget(filterForm.donorType) }}
                    </div>
                    <div class="admin-donation-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.status) }}
                        {{ form_widget(filterForm.status) }}
                    </div>
                    <div class="admin-donation-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.dateStart) }}
                        {{ form_widget(filterForm.dateStart) }}
                    </div>
                    <div class="admin-donation-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.dateEnd) }}
                        {{ form_widget(filterForm.dateEnd) }}
                    </div>
                    <div class="admin-donation-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.email) }}
                        {{ form_widget(filterForm.email) }}
                    </div>
                    <div class="admin-donation-form-group ui-field ui-field--compact">
                        {{ form_label(filterForm.companySiret) }}
                        {{ form_widget(filterForm.companySiret) }}
                    </div>
                </div>
                <div class="admin-donation-actions ui-actions">
                    <button
                        type="button"
                        id="reset-filters"
                        class="admin-donation-reset-button ui-button ui-button--secondary ui-button--filter"
                        aria-label="Réinitialiser les filtres de recherche"
                    >
                        Réinitialiser
                    </button>
                    <a
                        href="{{ path('admin_donation_download_pdfs', app.request.query.all) }}"
                        class="admin-donation-download-button ui-button ui-button--primary ui-button--filter"
                        aria-label="Télécharger les PDF correspondant à la recherche"
                    >
                        Télécharger les reçus fiscaux
                    </a>
                </div>
                {{ form_end(filterForm) }}
            </div>
            <div class="admin-donation-card ui-card">

                <div class="admin-donation-table-wrapper ui-table-wrapper">
                    <table class="admin-donation-table ui-table ui-table--1150">
                        <caption class="admin-donation-sr-only ui-sr-only">
                            Liste des donations enregistrées
                        </caption>
                        <thead>
                        <tr>
                            <th>Type</th>
                            <th>Donateur / Contact</th>
                            <th>Email</th>
                            <th>Adresse</th>
                            <th>Montant</th>
                            <th>Numéro reçu</th>
                            <th>Statut</th>
                            <th>Date</th>
                            <th>Reçu fiscal</th>
                            <th>Entreprise</th>
                            <th>SIRET</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for donation in donations %}
                            <tr>
                                <td>
                                <span class="admin-donation-badge ui-status">
                                    {% if donation.donorType.value == 'entreprise' %}
                                        Entreprise
                                    {% else %}
                                        Particulier
                                    {% endif %}
                                </span>
                                </td>
                                <td>{{ donation.firstname }} {{ donation.lastname }}</td>
                                <td>
                                    <a href="mailto:{{ donation.email }}">{{ donation.email }}</a>
                                </td>
                                <td>
                                    {{ donation.address }}<br>
                                    {{ donation.zipcode }} {{ donation.city }}
                                </td>
                                <td>
                                    <strong>
                                        {{ donation.amount|number_format(2, ',', ' ') }} €
                                    </strong>
                                </td>
                                <td>
                                    {{ donation.fiscalReceiptNumber ?? 'Non généré' }}
                                </td>
                                <td>
                                <span class="admin-donation-status admin-donation-status--{{ donation.status.value }} ui-status{% if donation.status.value == 'donation_validee' %} ui-status--success{% elseif donation.status.value == 'donation_passee' %} ui-status--warning{% elseif donation.status.value == 'donation_refusee' %} ui-status--danger{% endif %}">
                                    {% if donation.status.value == 'donation_validee' %}
                                        Validé
                                    {% elseif donation.status.value == 'donation_passee' %}
                                        En attente
                                    {% elseif donation.status.value == 'donation_refusee' %}
                                        Annulé
                                    {% else %}
                                        {{ donation.status.value }}
                                    {% endif %}
                                </span>
                                </td>
                                <td>{{ donation.donationDate|date('d/m/Y H:i') }}</td>
                                <td>
                                    {% if donation.receiptPdfPath %}
                                        <a
                                            href="{{ path('admin_donation_pdf', { id: donation.id }) }}"
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="admin-donation-link"
                                            aria-label="Voir le reçu fiscal du don {{ donation.fiscalReceiptNumber ?? donation.id }}"
                                        >
                                            Voir le reçu
                                        </a>
                                    {% else %}
                                        <span class="admin-donation-muted">Aucun reçu</span>
                                    {% endif %}
                                </td>
                                <td>{{ donation.companyName ?? '-' }}</td>
                                <td>{{ donation.companySiret ?? '-' }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="11" class="admin-donation-empty">
                                    Aucune donation trouvée.
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="admin-donation-pagination ui-pagination">
                    {{ knp_pagination_render(donations) }}
                </div>
            </div>
        </div>
    </section>
{% endblock %}

