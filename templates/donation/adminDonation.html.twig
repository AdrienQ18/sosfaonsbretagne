{% extends 'base.html.twig' %}

{% block body %}
    <h1>Administration des donations</h1>

    <table>
        <thead>
        <tr>
            <th>ID</th>
            <th>Donateur</th>
            <th>Email</th>
            <th>Montant</th>
            <th>Numéro du reçu fiscal</th>
            <th>Statut</th>
            <th>Date</th>
            <th>Reçu fiscal</th>
        </tr>
        </thead>

        <tbody>
        {% for donation in donations %}
            <tr>
                <td>{{ donation.id }}</td>
                <td>{{ donation.firstname }} {{ donation.lastname }}</td>
                <td>{{ donation.email }}</td>
                <td>{{ donation.amount }} €</td>
                <td>{{ donation.fiscalReceiptNumber }}</td>
                <td>{{ donation.status.value }}</td>
                <td>{{ donation.donationDate|date('d/m/Y H:i') }}</td>
                <td>
                    {% if donation.receiptPdfPath %}
                        <a href="{{ path('admin_donation_pdf', { id: donation.id }) }}" target="_blank">
                            Voir le PDF
                        </a>
                    {% else %}
                        Aucun PDF
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">Aucune donation trouvée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
