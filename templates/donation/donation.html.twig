{% extends 'base.html.twig' %}

{% block title %}
    Faire un don | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Soutenez SOS Faons Bretagne grâce à votre don. Votre contribution aide à protéger la faune sauvage et à soutenir les actions de terrain.
{% endblock %}

{% block robots %}
    <meta name="robots" content="index, follow">
{% endblock %}

{% block canonical %}
    <link rel="canonical" href="{{ absolute_url(path('donation')) }}">
{% endblock %}
{% block og_title %}
    Faire un don | SOS Faons Bretagne
{% endblock %}

{% block og_description %}
    Soutenez SOS Faons Bretagne grâce à votre don. Votre contribution aide à protéger la faune sauvage et à soutenir les actions de terrain.
{% endblock %}

{% block body %}

    <section class="ui-page ui-page--radial ui-page--compact">
        <noscript>
            <p class="alert alert-warning">
                JavaScript est nécessaire pour utiliser le formulaire de don.
            </p>
        </noscript>
        <div class="ui-container ui-container--1040 ui-container--mobile-620">

            <div class="ui-header ui-header--compact">
                <h1>Faire un don</h1>
                <p>Votre soutien fait toute la différence.</p>
                <p>
                    <span class="strong-text">Protéger le vivant demande du temps, du matériel et une présence sur le terrain. Votre don
                    nous aide à poursuivre cette mission essentielle et à accompagner les acteurs du territoire.</span>
                </p>
            </div>

            {{ form_start(formDonation, {
                attr: {
                    'data-turbo': 'false',
                    class: 'don-form'
                }
            }) }}

            <div class="don-layout">

                <div class="don-main">

                    {{ form_errors(formDonation) }}

                    <section id="step-amount" class="don-card ui-card">
                        <h2 class="visually-hidden">
                            Choisir le montant du don
                        </h2>
                        <div class="don-amount-grid">
                            <button type="button" class="don-amount-btn" data-amount="5"
                                    aria-label="Faire un don de 5 euros">5 €
                            </button>
                            <button type="button" class="don-amount-btn" data-amount="10"
                                    aria-label="Faire un don de 10 euros"
                            >10 €
                            </button>
                            <button type="button" class="don-amount-btn" data-amount="45"
                                    aria-label="Faire un don de 45 euros"
                            >45 €
                            </button>
                            <button type="button" class="don-amount-btn" data-amount="90"
                                    aria-label="Faire un don de 90 euros"
                            >90 €
                            </button>
                            <button type="button" class="don-amount-btn" data-amount="200"
                                    aria-label="Faire un don de 200 euros"
                            >200 €
                            </button>
                            <button type="button" class="don-amount-btn" data-amount="400"
                                    aria-label="Faire un don de 400 euros"
                            >400 €
                            </button>
                        </div>

                        <div class="don-free-amount">
                            {{ form_label(formDonation.amount, 'Montant libre') }}

                            {{ form_widget(formDonation.amount, {
                                attr: {
                                    placeholder: 'Montant libre',
                                    inputmode: 'decimal',
                                    autocomplete: 'off',
                                    'data-don-amount-input': 'true'
                                }
                            }) }}

                            <span class="don-currency">€</span>

                            {{ form_errors(formDonation.amount) }}
                        </div>

                        <button type="button" id="go-to-infos" class="don-primary-button ui-button ui-button--primary">
                            Faire un don
                        </button>

                    </section>

                    <section id="step-infos" class="don-card don-infos ui-card">
                        <h2 class="visually-hidden">
                            Informations du donateur
                        </h2>
                        <div class="don-radio-group">
                            {{ form_label(formDonation.donorType, 'Vous êtes') }}
                            {{ form_widget(formDonation.donorType) }}
                            {{ form_errors(formDonation.donorType) }}
                        </div>

                        <h2 id="donor-title" class="don-section-title">
                            Particulier donneur
                        </h2>

                        <div id="company-fields" style="display: none;">
                            <div class="don-form-group ui-field ui-field--don">
                                {{ form_label(formDonation.companyName) }}
                                {{ form_widget(formDonation.companyName) }}
                                {{ form_errors(formDonation.companyName) }}
                            </div>

                            <div class="don-form-group ui-field ui-field--don">
                                {{ form_label(formDonation.companySiret) }}
                                {{ form_widget(formDonation.companySiret) }}
                                {{ form_errors(formDonation.companySiret) }}
                            </div>
                        </div>

                        <h3 id="contact-title" class="don-subtitle">
                            Coordonnées
                        </h3>
                        <div class="ui-form-row ui-form-row--wide">
                            <div class="don-form-group ui-field ui-field--don">
                                {{ form_label(formDonation.firstname) }}
                                {{ form_widget(formDonation.firstname) }}
                                {{ form_errors(formDonation.firstname) }}
                            </div>

                            <div class="don-form-group ui-field ui-field--don">
                                {{ form_label(formDonation.lastname) }}
                                {{ form_widget(formDonation.lastname) }}
                                {{ form_errors(formDonation.lastname) }}
                            </div>
                        </div>
                        <div class="don-form-group ui-field ui-field--don">
                            {{ form_label(formDonation.email) }}
                            {{ form_widget(formDonation.email) }}
                            {{ form_errors(formDonation.email) }}
                        </div>

                        <div id="address-title" class="don-subtitle">
                            <h3>Adresse</h3>
                        </div>

                        <div class="don-form-group ui-field ui-field--don">
                            {{ form_label(formDonation.address) }}
                            {{ form_widget(formDonation.address) }}
                            {{ form_errors(formDonation.address) }}
                        </div>
                        <div class="ui-form-row ui-form-row--wide">

                            <div class="don-form-group ui-field ui-field--don">
                                {{ form_label(formDonation.zipcode) }}
                                {{ form_widget(formDonation.zipcode) }}
                                {{ form_errors(formDonation.zipcode) }}
                            </div>

                            <div class="don-form-group ui-field ui-field--don">
                                {{ form_label(formDonation.city) }}
                                {{ form_widget(formDonation.city) }}
                                {{ form_errors(formDonation.city) }}
                            </div>
                        </div>
                        <button
                            type="submit"
                            id="submit-donation"
                            class="don-submit-button ui-button ui-button--primary"
                            aria-live="polite"
                        >
                            Donner
                        </button>

                    </section>

                    <p class="don-secure">
                        Paiement 100 % sécurisé.
                    </p>

                    <p id="tax-info" class="don-tax-info">
                        Un reçu fiscal vous sera envoyé par e-mail après la confirmation de votre don.
                        66 % du montant de votre don est déductible des impôts.
                    </p>

                    <p class="don-helloasso-info">
                        HelloAsso propose une contribution supplémentaire lors du paiement.
                        Vous pouvez modifier ou supprimer ce montant librement.
                    </p>

                </div>

                <aside class="don-card don-side-card ui-card">
                    <h3>Exemples de dons</h3>

                    <div class="don-example-list">
                        <div class="don-example-item">
                            <strong>5 €</strong>
                            <span>Un premier pas pour agir</span>
                        </div>

                        <div class="don-example-item">
                            <strong>10 €</strong>
                            <span>Aide à financer un repérage de parcelle</span>
                        </div>

                        <div class="don-example-item">
                            <strong>45 €</strong>
                            <span>Soutient une intervention de sauvetage</span>
                        </div>

                        <div class="don-example-item">
                            <strong>90 €</strong>
                            <span>Participe à l’équipement des bénévoles</span>
                        </div>

                        <div class="don-example-item">
                            <strong>200 €</strong>
                            <span>Finance une journée complète de prospection</span>
                        </div>

                        <div class="don-example-item">
                            <strong>400 €</strong>
                            <span>Aidez-nous à financer un drone et bénéficiez d&#39;une immersion à nos côtés lors d&#39;une action de
                                    sauvegarde de la faune sauvage*.
                            </span>
                            <br>
                            <span>
                            * Sous réserve des besoins du terrain et des conditions de sécurité.
                            </span>
                        </div>

                        <div class="don-example-item">
                            <strong>Montant libre</strong>
                            <span>Je choisis mon engagement</span>
                        </div>
                    </div>
                </aside>

            </div>

            {{ form_end(formDonation) }}
        </div>
    </section>

{% endblock %}
