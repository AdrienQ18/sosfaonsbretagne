{% extends 'base.html.twig' %}

{% block body %}

    <h1>Faire un don</h1>

    <p>
        Votre soutien fait toute la différence.
    </p>

    <p>
        Grâce à votre générosité, nous pouvons sauver davantage de faons
        et poursuivre nos actions de protection sur le terrain.
    </p>

    {{ form_start(formDonation, {
        attr: {
            'data-turbo': 'false'
        }
    }) }}

    {{ form_errors(formDonation) }}

    <div id="step-amount" class="donation-amount">

        <button type="button" class="amount-btn" data-amount="5">5 €</button>
        <button type="button" class="amount-btn" data-amount="10">10 €</button>
        <button type="button" class="amount-btn" data-amount="45">45 €</button>
        <button type="button" class="amount-btn" data-amount="90">90 €</button>
        <button type="button" class="amount-btn" data-amount="200">200 €</button>
        <button type="button" class="amount-btn" data-amount="400">400 €</button>

        <div>
            {{ form_row(formDonation.amount, {
                attr: {
                    placeholder: 'Montant libre'
                }
            }) }}

            <span>€</span>
        </div>

        <button type="button" id="go-to-infos">
            Faire un don
        </button>

    </div>

    <div id="step-infos" class="donation-amount" style="display:none;">

        {{ form_row(formDonation.donorType) }}

        <h2 id="donor-title">
            Particulier donneur
        </h2>

        <div id="company-fields" style="display:none;">

            {{ form_row(formDonation.companyName) }}

            {{ form_row(formDonation.companySiret) }}

        </div>

        <h3 id="contact-title">
            Coordonnées
        </h3>

        {{ form_row(formDonation.firstname) }}
        {{ form_row(formDonation.lastname) }}
        {{ form_row(formDonation.email) }}

        <div id="address-title">
            <h3>Adresse</h3>
        </div>

        {{ form_row(formDonation.address) }}
        {{ form_row(formDonation.zipcode) }}
        {{ form_row(formDonation.city) }}

        <button type="submit" id="submit-donation">
            Donner
        </button>

    </div>

    <p>
        Paiement 100 % sécurisé.
    </p>

    <p id="tax-info">
        Un reçu fiscal vous sera envoyé par e-mail après la confirmation de votre don.
        66 % du montant de votre don est déductible des impôts.
    </p>

    <p>
        HelloAsso propose une contribution supplémentaire lors du paiement.
        Vous pouvez modifier ou supprimer ce montant librement.
    </p>
    {{ form_row(formDonation._token) }}
    {{ form_end(formDonation, { render_rest: false }) }}

    <div>

        <h3>Exemple de don</h3>

        <p>5 € : Un premier pas pour agir</p>
        <p>10 € : Aide à financer un repérage de parcelle</p>
        <p>45 € : Soutient une intervention de sauvetage</p>
        <p>90 € : Participe à l’équipement des bénévoles</p>
        <p>200 € : Finance une journée complète de prospection</p>
        <p>400 € : Aide à financer un drone et vivre une immersion à nos côtés</p>
        <p>Montant libre : Je choisis mon engagement</p>

    </div>

    <script>

        const stepAmount = document.querySelector('#step-amount');
        const stepInfos = document.querySelector('#step-infos');

        const amountInput = document.querySelector('#{{ formDonation.amount.vars.id }}');

        const submitBtn = document.querySelector('#submit-donation');

        const goToInfosBtn = document.querySelector('#go-to-infos');

        const taxInfo = document.querySelector('#tax-info');

        const donorTitle = document.querySelector('#donor-title');

        const addressTitle = document.querySelector('#address-title');

        const donorTypeSelector =
            'input[name="{{ formDonation.donorType.vars.full_name }}"]';

        const donorTypeInputs =
            document.querySelectorAll(donorTypeSelector);

        const companyFields =
            document.querySelector('#company-fields');

        const companyInputs = [
            document.querySelector('#{{ formDonation.companyName.vars.id }}'),
            document.querySelector('#{{ formDonation.companySiret.vars.id }}')
        ];

        document.querySelectorAll('.amount-btn').forEach(button => {

            button.addEventListener('click', () => {

                amountInput.value = button.dataset.amount;

                submitBtn.textContent =
                    'Donner ' + button.dataset.amount + ' €';

            });

        });

        goToInfosBtn.addEventListener('click', () => {

            if (!amountInput.value || Number(amountInput.value) <= 0) {

                alert('Veuillez choisir ou saisir un montant.');

                return;
            }

            stepAmount.style.display = 'none';

            stepInfos.style.display = 'block';

            submitBtn.textContent =
                'Donner ' + amountInput.value + ' €';

        });

        function setRequired(inputs, required) {

            inputs.forEach(input => {

                if (input) {
                    input.required = required;
                }

            });

        }

        function toggleDonorFields() {

            const selectedType =
                document.querySelector(donorTypeSelector + ':checked');

            if (!selectedType) {
                return;
            }

            if (selectedType.value === 'entreprise') {

                donorTitle.textContent =
                    'Entreprise donatrice';

                addressTitle.innerHTML =
                    '<h3>Adresse de l’entreprise</h3>';

                companyFields.style.display = 'block';

                setRequired(companyInputs, true);

                taxInfo.textContent =
                    'Un reçu fiscal vous sera envoyé par e-mail après la confirmation de votre don. ' +
                    '60 % du montant du don est déductible de l’impôt sur les sociétés.';

            } else {

                donorTitle.textContent =
                    'Particulier donneur';

                addressTitle.innerHTML =
                    '<h3>Adresse</h3>';

                companyFields.style.display = 'none';

                setRequired(companyInputs, false);

                taxInfo.textContent =
                    'Un reçu fiscal vous sera envoyé par e-mail après la confirmation de votre don. ' +
                    '66 % du montant de votre don est déductible des impôts.';
            }
        }

        donorTypeInputs.forEach(input => {

            input.addEventListener('change', toggleDonorFields);

        });

        toggleDonorFields();

    </script>

{% endblock %}
