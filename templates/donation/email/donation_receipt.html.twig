{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Merci pour votre don
{% endblock %}

{% block email_header %}
    <h1>Merci pour votre don</h1>
    <p>SOS Faons Bretagne</p>
{% endblock %}

{% block email_content %}

    {% if donation.donorType.value == 'entreprise' %}

        <p>Bonjour,</p>

        <p>
            Toute l’équipe de <strong>SOS Faons Bretagne</strong>
            remercie sincèrement
            <strong>{{ donation.companyName }}</strong>
            pour son don de
            <span class="email-amount">{{ donation.amount }} €</span>.
        </p>

        <p>
            Votre soutien nous aide à poursuivre nos actions de protection
            des faons et d’accompagnement des agriculteurs sur le terrain.
        </p>

        <h2>Informations de l'entreprise</h2>

        <div class="email-box">

            <p>
                <strong>Entreprise :</strong><br>
                {{ donation.companyName }}
            </p>

            <p>
                <strong>SIRET :</strong><br>
                {{ donation.companySiret }}
            </p>

            <p>
                <strong>Contact :</strong><br>
                {{ donation.firstname }} {{ donation.lastname }}
            </p>

            <p>
                <strong>Email :</strong><br>
                {{ donation.email }}
            </p>

            <p>
                <strong>Adresse :</strong><br>
                {{ donation.address }},
                {{ donation.zipcode }} {{ donation.city }}
            </p>

        </div>

    {% else %}

        <p>
            Bonjour {{ donation.firstname }} {{ donation.lastname }},
        </p>

        <p>
            Toute l’équipe de <strong>SOS Faons Bretagne</strong>
            vous remercie sincèrement pour votre don de
            <span class="email-amount">{{ donation.amount }} €</span>.
        </p>

        <p>
            Votre soutien nous aide à poursuivre nos actions de protection
            des faons et d’accompagnement des agriculteurs sur le terrain.
        </p>

        <h2>Informations du donateur</h2>

        <div class="email-box">

            <p>
                <strong>Donateur :</strong><br>
                {{ donation.firstname }} {{ donation.lastname }}
            </p>

            <p>
                <strong>Email :</strong><br>
                {{ donation.email }}
            </p>

            <p>
                <strong>Adresse :</strong><br>
                {{ donation.address }},
                {{ donation.zipcode }} {{ donation.city }}
            </p>

        </div>

    {% endif %}

    <h2>Détail du don</h2>

    <table class="email-table">

        <tr>
            <th>Montant du don</th>
            <td>{{ donation.amount }} €</td>
        </tr>

        <tr>
            <th>Date du don</th>
            <td>{{ donation.donationDate|date('d/m/Y') }}</td>
        </tr>

        <tr>
            <th>Numéro du reçu fiscal</th>
            <td>{{ donation.fiscalReceiptNumber }}</td>
        </tr>

        <tr>
            <th>Déduction fiscale</th>
            <td>
                {% if donation.donorType.value == 'entreprise' %}
                    60 % du montant du don est déductible de l'impôt sur les sociétés.
                {% else %}
                    66 % du montant de votre don est déductible des impôts.
                {% endif %}
            </td>
        </tr>

    </table>

    <div class="email-box">
        Votre reçu fiscal est joint à cet email au format PDF.
    </div>

    <p>
        Encore merci pour votre confiance et votre générosité.
    </p>

    <p>
        L'équipe <strong>SOS Faons Bretagne</strong>
    </p>

{% endblock %}

{% block email_footer %}
    Cet email a été généré automatiquement suite à la validation de votre don.<br>
    SOS Faons Bretagne — email@sosfaonsbretagne.fr
{% endblock %}
