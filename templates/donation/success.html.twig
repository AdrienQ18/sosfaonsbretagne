{% extends 'base.html.twig' %}

{% block title %}
    Don confirmé | SOS Faons Bretagne
{% endblock %}

{% block body %}

    <section class="donation-success-page">
        <div class="donation-success-card">

            <h1>Merci pour votre don</h1>

            <p>
                Votre paiement a bien été pris en compte par HelloAsso.
            </p>

