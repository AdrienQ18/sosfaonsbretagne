<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block email_title %}SOS Faons Bretagne{% endblock %}</title>
</head>

<body style="margin:0; padding:0; background-color:#f6f1e8; font-family:Arial, Helvetica, sans-serif; color:#2b2b2b;">

<table
    width="100%"
    cellpadding="0"
    cellspacing="0"
    border="0"
    role="presentation"
    style="width:100%; background-color:#f6f1e8; padding:30px 0;"
>
    <tr>
        <td align="center">

            <table
                width="600"
                cellpadding="0"
                cellspacing="0"
                border="0"
                role="presentation"
                style="width:600px; max-width:600px; background-color:#ffffff;"
            >

                <tr>
                    <td
                        align="center"
                        style="background-color:#1b4a3a; padding:30px 24px; color:#ffffff;"
                    >
                        <img
                            src="{{ email.image('@images/logo.jpg') }}"
                            alt="Logo SOS Faons Bretagne"
                            width="110"
                            style="display:block; width:110px; height:auto; margin:0 auto 16px auto; border:0;"
                        >

                        {% block email_header %}
                            <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3; font-weight:bold;">
                                SOS Faons Bretagne
                            </h1>

                            <p style="margin:8px 0 0 0; color:#ffffff; font-size:14px; line-height:1.5;">
                                Protection des faons et de la faune sauvage
                            </p>
                        {% endblock %}
                    </td>
                </tr>

                <tr>
                    <td
                        style="padding:32px; color:#2b2b2b; font-size:15px; line-height:1.7;"
                    >
                        {% block email_content %}{% endblock %}
                    </td>
                </tr>

                <tr>
                    <td
                        style="background-color:#f4efe8; padding:20px 32px; color:#6f6f6f; font-size:12px; line-height:1.6;"
                    >
                        {% block email_footer %}
                            Cet email a été envoyé automatiquement par SOS Faons Bretagne.<br>
                            Merci de ne pas y répondre.
                        {% endblock %}
                    </td>
                </tr>

            </table>

        </td>
    </tr>
</table>

</body>
</html>
