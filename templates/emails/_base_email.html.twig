<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block email_title %}SOS Faons Bretagne{% endblock %}</title>
</head>

<body style="margin:0;padding:0;background:#f6f1e8;font-family:Arial,Helvetica,sans-serif;">

<table
    role="presentation"
    width="100%"
    cellpadding="0"
    cellspacing="0"
    border="0"
    style="background:#f6f1e8;padding:30px 0;"
>
    <tr>
        <td align="center">

            <table
                role="presentation"
                width="600"
                cellpadding="0"
                cellspacing="0"
                border="0"
                style="
                    width:600px;
                    max-width:600px;
                    background:#ffffff;
                    border-radius:12px;
                    overflow:hidden;
                    border:1px solid #e8e1d8;
                "
            >

                <tr>
                    <td
                        align="center"
                        style="
                            background:#1b4a3a;
                            padding:30px;
                        "
                    >

                        <img
                            src="{{ email.image('@images/logo.jpg') }}"
                            alt="SOS Faons Bretagne"
                            width="100"
                            style="display:block;border:0;"
                        >

                        {% block email_header %}
                            <h1
                                style="
                                    margin:20px 0 8px;
                                    color:#ffffff;
                                    font-size:28px;
                                    font-weight:bold;
                                "
                            >
                                SOS Faons Bretagne
                            </h1>

                            <p
                                style="
                                    margin:0;
                                    color:#dce8e1;
                                    font-size:14px;
                                "
                            >
                                Protection des faons et de la biodiversité
                            </p>
                        {% endblock %}

                    </td>
                </tr>

                <tr>
                    <td
                        style="
                            padding:35px;
                            color:#2b2b2b;
                            font-size:15px;
                            line-height:1.7;
                        "
                    >
                        {% block email_content %}{% endblock %}
                    </td>
                </tr>

                <tr>
                    <td
                        style="
                            background:#f4efe8;
                            border-top:1px solid #e6ddd1;
                            padding:22px 30px;
                            font-size:12px;
                            line-height:1.6;
                            color:#6f6f6f;
                        "
                    >
                        {% block email_footer %}
                            SOS Faons Bretagne<br>
                            11 Louvel – 35140 Gosné<br><br>

                            Cet email a été envoyé automatiquement.
                        {% endblock %}
                    </td>
                </tr>

            </table>

        </td>
    </tr>
</table>

</body>
</html>
