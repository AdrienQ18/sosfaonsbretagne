{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Nouveau message de contact
{% endblock %}

{% block email_header %}
    <h1 style="margin:20px 0 8px;color:#ffffff;font-size:26px;line-height:1.3;font-weight:bold;">
        Nouveau message de contact
    </h1>

    <p style="margin:0;color:#dce8e1;font-size:14px;line-height:1.5;">
        SOS Faons Bretagne
    </p>
{% endblock %}

{% block email_content %}

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin-bottom:24px;">
        <tr>
            <td style="background:#f4efe8;border-left:4px solid #6e8e64;padding:16px;color:#2b2b2b;">
                Un nouveau message a été envoyé depuis la page contact du site.
            </td>
        </tr>
    </table>

    <h2 style="margin:0 0 16px;color:#1b4a3a;font-size:20px;font-weight:bold;">
        Informations du contact
    </h2>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="border-collapse:collapse;margin-bottom:30px;">
        <tr>
            <td style="background:#f4efe8;border:1px solid #ddd5cc;padding:12px;width:160px;color:#1b4a3a;font-weight:bold;">Prénom</td>
            <td style="border:1px solid #ddd5cc;padding:12px;">{{ contact.firstname }}</td>
        </tr>
        <tr>
            <td style="background:#f4efe8;border:1px solid #ddd5cc;padding:12px;color:#1b4a3a;font-weight:bold;">Nom</td>
            <td style="border:1px solid #ddd5cc;padding:12px;">{{ contact.lastname }}</td>
        </tr>
        <tr>
            <td style="background:#f4efe8;border:1px solid #ddd5cc;padding:12px;color:#1b4a3a;font-weight:bold;">Email</td>
            <td style="border:1px solid #ddd5cc;padding:12px;">{{ contact.email }}</td>
        </tr>
        <tr>
            <td style="background:#f4efe8;border:1px solid #ddd5cc;padding:12px;color:#1b4a3a;font-weight:bold;">Sujet</td>
            <td style="border:1px solid #ddd5cc;padding:12px;">{{ contact.subject }}</td>
        </tr>
    </table>

    <h2 style="margin:0 0 16px;color:#1b4a3a;font-size:20px;font-weight:bold;">
        Message
    </h2>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation">
        <tr>
            <td style="background:#f4efe8;border-left:4px solid #6e8e64;padding:16px;color:#2b2b2b;line-height:1.7;">
                {{ contact.message|nl2br }}
            </td>
        </tr>
    </table>

{% endblock %}

{% block email_footer %}
    Notification automatique SOS Faons Bretagne.<br>
    Merci de ne pas répondre directement à cet email.
{% endblock %}
