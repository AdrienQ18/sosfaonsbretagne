{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Nouveau message de contact
{% endblock %}

{% block email_header %}
    <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3;">
        Nouveau message de contact
    </h1>

    <p style="margin:8px 0 0 0; color:#ffffff;">
        SOS Faons Bretagne
    </p>
{% endblock %}

{% block email_content %}

    <div
        style="
            background-color:#f4efe8;
            border-left:4px solid #6e8e64;
            padding:16px;
            margin-bottom:24px;
            color:#2b2b2b;
        "
    >
        Un nouveau message a été envoyé depuis la page contact du site.
    </div>

    <h2
        style="
            color:#1b4a3a;
            font-size:20px;
            margin:0 0 16px 0;
        "
    >
        Informations du contact
    </h2>

    <table
        width="100%"
        cellpadding="0"
        cellspacing="0"
        border="0"
        style="
            border-collapse:collapse;
            margin-bottom:30px;
        "
    >

        <tr>
            <td
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    font-weight:bold;
                    width:160px;
                    color:#1b4a3a;
                "
            >
                Prénom
            </td>

            <td
                style="
                    border:1px solid #ddd5cc;
                    padding:12px;
                "
            >
                {{ contact.firstname }}
            </td>
        </tr>

        <tr>
            <td
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    font-weight:bold;
                    color:#1b4a3a;
                "
            >
                Nom
            </td>

            <td
                style="
                    border:1px solid #ddd5cc;
                    padding:12px;
                "
            >
                {{ contact.lastname }}
            </td>
        </tr>

        <tr>
            <td
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    font-weight:bold;
                    color:#1b4a3a;
                "
            >
                Email
            </td>

            <td
                style="
                    border:1px solid #ddd5cc;
                    padding:12px;
                "
            >
                {{ contact.email }}
            </td>
        </tr>

        <tr>
            <td
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    font-weight:bold;
                    color:#1b4a3a;
                "
            >
                Sujet
            </td>

            <td
                style="
                    border:1px solid #ddd5cc;
                    padding:12px;
                "
            >
                {{ contact.subject }}
            </td>
        </tr>

    </table>

    <h2
        style="
            color:#1b4a3a;
            font-size:20px;
            margin:0 0 16px 0;
        "
    >
        Message
    </h2>

    <div
        style="
            background-color:#f4efe8;
            border-left:4px solid #6e8e64;
            padding:16px;
            color:#2b2b2b;
            line-height:1.7;
        "
    >
        {{ contact.message|nl2br }}
    </div>

{% endblock %}

{% block email_footer %}
    Notification automatique SOS Faons Bretagne.<br>
    Merci de ne pas répondre directement à cet email.
{% endblock %}
