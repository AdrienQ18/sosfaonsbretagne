{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Merci pour votre don
{% endblock %}

{% block email_header %} <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3;">
    Merci pour votre don </h1>

    <p style="margin:8px 0 0 0; color:#ffffff;">
        SOS Faons Bretagne
    </p>

{% endblock %}

{% block email_content %}

    {% if donation.donorType.value == 'entreprise' %}

        <p style="margin:0 0 18px 0;">
            Bonjour,
        </p>

        <p style="margin:0 0 18px 0;">
            Toute l'équipe de <strong>SOS Faons Bretagne</strong> remercie sincèrement
            <strong>{{ donation.companyName }}</strong> pour son don de
            <span style="color:#1b4a3a; font-size:22px; font-weight:bold;">
            {{ donation.amount|number_format(2, ',', ' ') }} €
        </span>.
        </p>

    {% else %}

        <p style="margin:0 0 18px 0;">
            Bonjour {{ donation.firstname }} {{ donation.lastname }},
        </p>

        <p style="margin:0 0 18px 0;">
            Toute l'équipe de <strong>SOS Faons Bretagne</strong> vous remercie sincèrement pour votre don de
            <span style="color:#1b4a3a; font-size:22px; font-weight:bold;">
            {{ donation.amount|number_format(2, ',', ' ') }} €
        </span>.
        </p>

    {% endif %}

    <p style="margin:0 0 24px 0;">
        Votre soutien nous aide à poursuivre nos actions de protection des faons
        et d'accompagnement des agriculteurs sur le terrain.
    </p>

    {% if donation.donorType.value == 'entreprise' %}

        <h2 style="margin:0 0 16px 0; color:#1b4a3a; font-size:20px; font-weight:bold;">
            Informations de l'entreprise
        </h2>

        <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin-bottom:26px;">
            <tr>
                <td style="background:#f4efe8; border-left:4px solid #6e8e64; padding:18px; color:#2b2b2b; line-height:1.6;">
                    <p style="margin:0 0 16px 0;"><strong>Entreprise :</strong><br>{{ donation.companyName }}</p>
                    <p style="margin:0 0 16px 0;"><strong>SIRET :</strong><br>{{ donation.companySiret }}</p>
                    <p style="margin:0 0 16px 0;"><strong>Contact :</strong><br>{{ donation.firstname }} {{ donation.lastname }}</p>
                    <p style="margin:0 0 16px 0;"><strong>Email :</strong><br>{{ donation.email }}</p>
                    <p style="margin:0;"><strong>Adresse :</strong><br>{{ donation.address }}, {{ donation.zipcode }} {{ donation.city }}</p>
                </td>
            </tr>
        </table>

    {% else %}

        <h2 style="margin:0 0 16px 0; color:#1b4a3a; font-size:20px; font-weight:bold;">
            Informations du donateur
        </h2>

        <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin-bottom:26px;">
            <tr>
                <td style="background:#f4efe8; border-left:4px solid #6e8e64; padding:18px; color:#2b2b2b; line-height:1.6;">
                    <p style="margin:0 0 16px 0;"><strong>Donateur :</strong><br>{{ donation.firstname }} {{ donation.lastname }}</p>
                    <p style="margin:0 0 16px 0;"><strong>Email :</strong><br>{{ donation.email }}</p>
                    <p style="margin:0;"><strong>Adresse :</strong><br>{{ donation.address }}, {{ donation.zipcode }} {{ donation.city }}</p>
                </td>
            </tr>
        </table>

    {% endif %}

    <h2 style="margin:0 0 16px 0; color:#1b4a3a; font-size:20px; font-weight:bold;">
        Détail du don
    </h2>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="border-collapse:collapse; margin-bottom:26px;">
        <tr>
            <td style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; width:180px; color:#1b4a3a; font-weight:bold;">
                Montant du don
            </td>
            <td style="border:1px solid #ddd5cc; padding:12px;">
                {{ donation.amount|number_format(2, ',', ' ') }} €
            </td>
        </tr>

        <tr>
            <td style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; color:#1b4a3a; font-weight:bold;">
                Date du don
            </td>
            <td style="border:1px solid #ddd5cc; padding:12px;">
                {{ donation.donationDate|date('d/m/Y') }}
            </td>
        </tr>

        <tr>
            <td style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; color:#1b4a3a; font-weight:bold;">
                Numéro du reçu fiscal
            </td>
            <td style="border:1px solid #ddd5cc; padding:12px;">
                {{ donation.fiscalReceiptNumber }}
            </td>
        </tr>

        <tr>
            <td style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; color:#1b4a3a; font-weight:bold;">
                Déduction fiscale
            </td>
            <td style="border:1px solid #ddd5cc; padding:12px;">
                {% if donation.donorType.value == 'entreprise' %}
                    60 % du montant du don est déductible de l'impôt sur les sociétés.
                {% else %}
                    66 % du montant de votre don est déductible des impôts.
                {% endif %}
            </td>
        </tr>
    </table>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin-bottom:24px;">
        <tr>
            <td style="background:#f4efe8; border-left:4px solid #6e8e64; padding:16px; color:#2b2b2b; line-height:1.6;">
                Votre reçu fiscal est joint à cet email au format PDF.
            </td>
        </tr>
    </table>

    <p style="margin:0 0 18px 0;">
        Encore merci pour votre confiance et votre générosité.
    </p>

    <p style="margin:0;">
        L'équipe <strong>SOS Faons Bretagne</strong>
    </p>

{% endblock %}

{% block email_footer %}
    Cet email a été généré automatiquement suite à la validation de votre don.<br>
    SOS Faons Bretagne — [contact@sosfaonsbretagne.fr](mailto:contact@sosfaonsbretagne.fr)
{% endblock %}
