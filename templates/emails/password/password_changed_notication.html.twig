{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Mot de passe modifié
{% endblock %}

{% block email_header %} <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3;">

    Mot de passe modifié </h1>
    <p style="margin:8px 0 0 0; color:#ffffff;">
        SOS Faons Bretagne
    </p>

{% endblock %}

{% block email_content %}

    <p style="margin:0 0 18px 0;">
        Bonjour {{ user.firstname }},
    </p>

    <p style="margin:0 0 18px 0;">
        Nous vous confirmons que le mot de passe associé à votre compte
        <strong>SOS Faons Bretagne</strong> a été modifié avec succès.
    </p>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:20px 0;">
        <tr>
            <td style="background:#f4efe8;border-left:4px solid #6e8e64;padding:16px;color:#2b2b2b;line-height:1.6;">
                Si vous êtes à l'origine de cette modification, aucune action supplémentaire n'est nécessaire.
            </td>
        </tr>
    </table>

    <p style="margin:0 0 18px 0;">
        Si vous n'avez pas effectué cette modification, nous vous recommandons de nous contacter rapidement afin de sécuriser votre compte.
    </p>

    <p style="margin:24px 0 0 0;">
        Cordialement,<br>
        <strong>L'équipe SOS Faons Bretagne</strong>
    </p>

{% endblock %}

{% block email_footer %}
    Cet email vous a été envoyé automatiquement suite à la modification du mot de passe de votre compte.<br>
    Pour toute question, vous pouvez nous contacter à l'adresse : [contact@sosfaonsbretagne.fr](mailto:contact@sosfaonsbretagne.fr)
{% endblock %}
