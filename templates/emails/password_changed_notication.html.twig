{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Mot de passe modifié
{% endblock %}

{% block email_header %}
    <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3;">
        Mot de passe modifié
    </h1>

    <p style="margin:8px 0 0 0; color:#ffffff;">
        SOS Faons Bretagne
    </p>
{% endblock %}

{% block email_content %}

    <p style="margin:0 0 18px 0;">
        Bonjour {{ user.firstname }},
    </p>

    <p style="margin:0 0 18px 0;">
        Votre mot de passe a bien été modifié.
    </p>

    <div
        style="
            background-color:#f4efe8;
            border-left:4px solid #6e8e64;
            padding:16px;
            margin:20px 0;
            color:#2b2b2b;
            line-height:1.6;
        "
    >
        Si vous êtes bien à l'origine de cette modification, aucune action supplémentaire n'est nécessaire.
    </div>

    <p style="margin:0 0 18px 0;">
        Si vous n'êtes pas à l'origine de ce changement, nous vous conseillons de contacter rapidement l'association.
    </p>

    <p style="margin:0;">
        L'équipe <strong>SOS Faons Bretagne</strong>
    </p>

{% endblock %}

{% block email_footer %}
    Cet email a été envoyé automatiquement après la modification de votre mot de passe.<br>
    SOS Faons Bretagne — contact@sosfaonsbretagne.fr
{% endblock %}
