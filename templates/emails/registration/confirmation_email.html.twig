{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Confirmation de votre adresse email
{% endblock %}

{% block email_header %} <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3;">
    Bienvenue sur SOS Faons Bretagne </h1>

    <p style="margin:8px 0 0 0; color:#ffffff;">
        Confirmation de votre adresse email
    </p>

{% endblock %}

{% block email_content %}


    <p style="margin:0 0 18px 0;">
        Bonjour,
    </p>

    <p style="margin:0 0 18px 0;">
        Merci pour votre inscription sur <strong>SOS Faons Bretagne</strong>.
    </p>

    <p style="margin:0 0 18px 0;">
        Afin de finaliser la création de votre compte et de sécuriser votre accès,
        nous vous invitons à confirmer votre adresse email.
    </p>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:24px 0;">
        <tr>
            <td align="center">
                <a
                    href="{{ signedUrl|raw }}"
                    style="
                    display:inline-block;
                    padding:14px 28px;
                    background-color:#1b4a3a;
                    color:#ffffff;
                    text-decoration:none;
                    font-weight:bold;
                    border-radius:8px;
                "
                >
                    Confirmer mon adresse email
                </a>
            </td>
        </tr>
    </table>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:20px 0;">
        <tr>
            <td style="
            background-color:#f4efe8;
            border-left:4px solid #6e8e64;
            padding:16px;
            color:#2b2b2b;
            line-height:1.6;
        ">
                Ce lien expirera dans
                <strong>
                    {{ expiresAtMessageKey|trans(
                        expiresAtMessageData,
                        'VerifyEmailBundle'
                    ) }}
                </strong>.
            </td>
        </tr>
    </table>

    <p style="margin:0 0 18px 0;">
        Une fois votre adresse validée, vous pourrez accéder à l'ensemble des fonctionnalités du site :
        gestion de votre profil, signalement de fauchage, suivi des actions de l'association et bien plus encore.
    </p>

    <p style="margin:0;">
        Si vous n'êtes pas à l'origine de cette inscription, vous pouvez ignorer cet email en toute sécurité.
    </p>

{% endblock %}

{% block email_footer %}
    Cet email vous a été envoyé automatiquement lors de la création d'un compte sur SOS Faons Bretagne.<br>
    Pour toute question, vous pouvez nous contacter à l'adresse : [contact@sosfaonsbretagne.fr](mailto: contact@sosfaonsbretagne.fr)
{% endblock %}
