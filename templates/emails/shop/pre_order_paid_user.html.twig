{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Paiement confirmé
{% endblock %}

{% block email_header %} <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3;">
    Paiement confirmé </h1>

    <p style="margin:8px 0 0 0; color:#ffffff;">
        SOS Faons Bretagne
    </p>

{% endblock %}

{% block email_content %}

    <p style="margin:0 0 18px 0;">
        Bonjour {{ preOrder.user.firstname }},
    </p>

    <p style="margin:0 0 18px 0;">
        Votre paiement pour la précommande
        <strong>n°{{ preOrder.id }}</strong>
        a bien été confirmé.
    </p>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:20px 0 24px 0;">
        <tr>
            <td style="background-color:#f4efe8; border-left:4px solid #6e8e64; padding:16px; color:#2b2b2b; line-height:1.6;">
                Votre commande est désormais enregistrée et en cours de traitement.
            </td>
        </tr>
    </table>

    <h2 style="margin:0 0 16px 0; color:#1b4a3a; font-size:20px; font-weight:bold;">
        Récapitulatif
    </h2>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="border-collapse:collapse; margin-bottom:24px;">

        <tr>
            <td style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; width:200px; color:#1b4a3a; font-weight:bold;">
                Numéro de précommande
            </td>

            <td style="border:1px solid #ddd5cc; padding:12px;">
                #{{ preOrder.id }}
            </td>
        </tr>

        <tr>
            <td style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; color:#1b4a3a; font-weight:bold;">
                Montant total
            </td>

            <td style="border:1px solid #ddd5cc; padding:12px;">
            <span style="color:#1b4a3a; font-size:22px; font-weight:bold;">
                {{ preOrder.totalAmount|number_format(2, ',', ' ') }} €
            </span>
            </td>
        </tr>

        <tr>
            <td style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; color:#1b4a3a; font-weight:bold;">
                Date de précommande
            </td>

            <td style="border:1px solid #ddd5cc; padding:12px;">
                {{ preOrder.preOrderDate|date('d/m/Y') }}
            </td>
        </tr>

        <tr>
            <td style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; color:#1b4a3a; font-weight:bold;">
                Statut
            </td>

            <td style="border:1px solid #ddd5cc; padding:12px; color:#207245; font-weight:bold;">
                Paiement confirmé
            </td>
        </tr>

    </table>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin-bottom:24px;">
        <tr>
            <td style="background-color:#f4efe8; border-left:4px solid #6e8e64; padding:16px; color:#2b2b2b; line-height:1.6;">
                Votre facture est jointe à cet email au format PDF.
            </td>
        </tr>
    </table>

    <p style="margin:0 0 18px 0;">
        Merci pour votre confiance et votre soutien à nos actions de protection des faons.
    </p>

    <p style="margin:0;">
        L'équipe <strong>SOS Faons Bretagne</strong>
    </p>

{% endblock %}

{% block email_footer %}
    Cet email a été généré automatiquement suite à la confirmation de votre paiement.<br>
    SOS Faons Bretagne — [contact@sosfaonsbretagne.fr](mailto:contact@sosfaonsbretagne.fr)
{% endblock %}
