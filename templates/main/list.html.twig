{% extends 'base.html.twig' %}

{% block title %}
    Actualités{% if app.request.query.getInt('page', 1) > 1 %} - page {{ app.request.query.getInt('page', 1) }}{% endif %} | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Retrouvez les actualités, événements et publications de SOS Faons Bretagne{% if app.request.query.getInt('page', 1) > 1 %}, page {{ app.request.query.getInt('page', 1) }}{% endif %}.
{% endblock %}

{% block robots %}
    <meta name="robots" content="index, follow">
{% endblock %}

{% block canonical %}
    {% set currentPage = app.request.query.getInt('page', 1) %}
    <link rel="canonical" href="{{ currentPage > 1 ? absolute_url(path('event_list', { page: currentPage })) : absolute_url(path('event_list')) }}">
{% endblock %}

{% block og_title %}
    Actualités{% if app.request.query.getInt('page', 1) > 1 %} - page {{ app.request.query.getInt('page', 1) }}{% endif %} | SOS Faons Bretagne
{% endblock %}

{% block og_description %}
    Retrouvez les actualités, événements et publications de SOS Faons Bretagne{% if app.request.query.getInt('page', 1) > 1 %}, page {{ app.request.query.getInt('page', 1) }}{% endif %}.
{% endblock %}

{% block og_url %}
    {% set currentPage = app.request.query.getInt('page', 1) %}
    {{ currentPage > 1 ? absolute_url(path('event_list', { page: currentPage })) : absolute_url(path('event_list')) }}
{% endblock %}

{% block body %}

    <section class="ui-page ui-page--radial">

        <div class="ui-container ui-container--1180">

            <header class="ui-header ui-header--center">
                <h1>Actualités</h1>

                <p>
                    Retrouvez les dernières nouvelles, événements et publications
                    de SOS Faons Bretagne.
                </p>
            </header>

            <div class="post-grid">

                {% for event in events %}

                    <article class="post-card ui-card">

                        <div class="post-photo">
                            {% if event.image %}
                                <img
                                    src="{{ asset('images/event/' ~ event.image) }}"
                                    alt="{{ event.name }}"
                                    loading="lazy"
                                >
                            {% else %}
                                <div class="post-no-image">
                                    Image indisponible
                                </div>
                            {% endif %}
                        </div>

                        <div class="post-content">

                            <div class="post-meta">
                                <span class="post-type">
                                    {{ event.type }}
                                </span>

                                <span class="post-date">
                                    {{ event.eventDate|date('d/m/Y') }}
                                </span>
                            </div>

                            <h2>{{ event.name }}</h2>

                            <p>
                                {{ event.description|nl2br }}
                            </p>

                            {% if is_granted("ROLE_ADMIN") %}

                                <div class="post-admin-status">
                                    {% if event.isPublished %}
                                        Publié
                                    {% else %}
                                        Enregistré
                                    {% endif %}
                                </div>

                                <div class="post-admin-actions">

                                    <a
                                        href="{{ path('event_modify', { id: event.id }) }}"
                                        class="post-admin-button post-admin-button--edit ui-button ui-button--primary"
                                        onclick="return confirm('Êtes-vous sûr de vouloir modifier ce post ?')"
                                    >
                                        Modifier
                                    </a>

                                    <form
                                        method="post"
                                        action="{{ path('event_delete', { id: event.id }) }}"
                                        onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce post ?');"
                                    >
                                        <button
                                            type="submit"
                                            class="post-admin-button post-admin-button--delete ui-button ui-button--delete"
                                        >
                                            Supprimer
                                        </button>
                                    </form>

                                </div>

                            {% endif %}

                        </div>

                    </article>

                {% else %}

                    <div class="post-empty ui-empty-state ui-card">
                        <h2>Aucune actualité</h2>

                        <p>
                            Aucune publication n'est disponible pour le moment.
                        </p>
                    </div>

                {% endfor %}

            </div>

        </div>

        <div class="post-pagination ui-pagination">
            {{ knp_pagination_render(events) }}
        </div>

    </section>

{% endblock %}
