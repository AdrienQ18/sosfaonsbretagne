{% extends 'base.html.twig' %}

{% block title %}
    Actualités | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Retrouvez les actualités, événements et publications de SOS Faons Bretagne.
{% endblock %}

{% block robots %}
    <meta name="robots" content="index, follow">
{% endblock %}

{% block canonical %}
    <link rel="canonical" href="{{ absolute_url(path('event_list')) }}">
{% endblock %}

{% block body %}

    <section class="post-page">

        <div class="post-container">

            <header class="post-header">
                <h1>Actualités</h1>

                <p>
                    Retrouvez les dernières nouvelles, événements et publications
                    de SOS Faons Bretagne.
                </p>
            </header>

            <div class="post-grid">

                {% for event in events %}

                    <article class="post-card">

                        <div class="post-photo">
                            {% if event.image %}
                                <img
                                    src="{{ asset('images/event/' ~ event.image) }}"
                                    alt="{{ event.name }}"
                                    loading="lazy"
                                >
                            {% else %}
                                <div class="post-no-image">
                                    Image indisponible
                                </div>
                            {% endif %}
                        </div>

                        <div class="post-content">

                            <div class="post-meta">
                                <span class="post-type">
                                    {{ event.type }}
                                </span>

                                <span class="post-date">
                                    {{ event.eventDate|date('d/m/Y') }}
                                </span>
                            </div>

                            <h2>{{ event.name }}</h2>

                            <p>
                                {{ event.description|replace({'\\n':'<br>'})|raw }}
                            </p>

                            {% if is_granted("ROLE_ADMIN") %}

                                <div class="post-admin-status">
                                    {% if event.isPublished %}
                                        Publié
                                    {% else %}
                                        Enregistré
                                    {% endif %}
                                </div>

                                <div class="post-admin-actions">

                                    <a
                                        href="{{ path('event_modify', { id: event.id }) }}"
                                        class="post-admin-button post-admin-button--edit"
                                        onclick="return confirm('Êtes-vous sûr de vouloir modifier ce post ?')"
                                    >
                                        Modifier
                                    </a>

                                    <a
                                        href="{{ path('event_delete', { id: event.id }) }}"
                                        class="post-admin-button post-admin-button--delete"
                                        onclick="return confirm('Êtes-vous sûr de vouloir supprimer ce post ?')"
                                    >
                                        Supprimer
                                    </a>

                                </div>

                            {% endif %}

                        </div>

                    </article>

                {% else %}

                    <div class="post-empty">
                        <h2>Aucune actualité</h2>

                        <p>
                            Aucune publication n'est disponible pour le moment.
                        </p>
                    </div>

                {% endfor %}

            </div>

        </div>

    </section>

{% endblock %}
