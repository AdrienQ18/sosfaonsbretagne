<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block pdf_title %}Document PDF{% endblock %}</title>

    <style>
        @page {
            margin: 15px;
        }

        body {
            margin: 0;
            font-family: DejaVu Sans, Arial, sans-serif;
            font-size: 10px;
            color: #2b2b2b;
            line-height: 1.25;
            background: #ffffff;
        }

        .pdf-header {
            padding: 14px 0 16px;
            margin-bottom: 10px;
            border-bottom: 4px solid #1b4a3a;
        }

        .pdf-logo {
            width: 55px;
            height: auto;
            display: block;
            margin-bottom: 10px;
        }

        .pdf-title {
            margin: 0;
            color: #1b4a3a;
            font-size: 18px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .pdf-subtitle {
            margin: 5px 0 0;
            color: #6e8e64;
            font-size: 11px;
            font-weight: bold;
        }

        .pdf-section {
            margin-bottom: 8px;
            padding: 8px;
            border: 1px solid #ddd5cc;
            background: #fbfaf7;
        }

        .pdf-section-title {
            margin: 0 0 8px;
            color: #1b4a3a;
            font-size: 13px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .pdf-row {
            margin-bottom: 2px;
        }

        .pdf-label {
            color: #1b4a3a;
            font-weight: bold;
        }

        .pdf-table {
            width: 100%;
            margin: 14px 0;
            border-collapse: collapse;
        }

        .pdf-table th,
        .pdf-table td {
            padding: 8px;
            border: 1px solid #ddd5cc;
            text-align: left;
            vertical-align: top;
        }

        .pdf-table th {
            background: #f4efe8;
            color: #1b4a3a;
            font-weight: bold;
        }

        .pdf-total {
            margin-top: 18px;
            padding: 12px;
            background: #f4efe8;
            color: #1b4a3a;
            font-size: 17px;
            font-weight: bold;
            text-align: right;
        }

        .pdf-two-columns {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 14px;
        }

        .pdf-two-columns td {
            width: 50%;
            vertical-align: top;
        }

        .pdf-left {
            padding-right: 4px;
        }

        .pdf-right {
            padding-left: 4px;
        }

        .pdf-note {
            margin-top: 12px;
            padding: 10px;
            background: #f4efe8;
            border-left: 4px solid #6e8e64;
            color: #2b2b2b;
        }
        .pdf-signature-table {
            width: 100%;
            margin-top: 8px;
        }

        .pdf-signature-cell {
            width: 180px;
            text-align: center;
        }

        .pdf-signature-cell img {
            width: 70px;
        }
        .pdf-footer {
            margin-top: 10px;
            padding-top: 6px;
            border-top: 1px solid #ddd5cc;
            color: #666666;
            font-size: 8px;
            line-height: 1.45;
            text-align: justify;
        }

        .pdf-reference-box {
            margin-top: 12px;
            padding: 10px 12px;
            background: #f4efe8;
            border-left: 4px solid #6e8e64;
        }

        .pdf-legal-reference {
            margin: 8px 0 14px;
            color: #1b4a3a;
            font-style: italic;
            text-align: center;
        }

        .pdf-signature {
            margin-top: 14px;
            text-align: right;
        }

        .pdf-signature img {
            width: 95px;
            height: auto;
        }
    </style>
</head>

<body>

<div class="pdf-header">
    {% block pdf_header %}{% endblock %}
</div>

{% block pdf_content %}{% endblock %}

<div class="pdf-footer">
    {% block pdf_footer %}
        Document généré automatiquement par SOS Faons Bretagne.
    {% endblock %}
</div>

</body>
</html>
