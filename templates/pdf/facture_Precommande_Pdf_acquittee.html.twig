{% extends 'pdf/_base_pdf.html.twig' %}

{% block pdf_title %}
    Facture {{ invoiceNumber }}
{% endblock %}

{% block pdf_header %}

    <img class="pdf-logo" src="{{ logoPath }}" alt="Logo SOS Faons Bretagne">

    <h1 class="pdf-title">Facture acquittée</h1>
    <p class="pdf-subtitle">Précommande validée et payée</p>

    <div class="pdf-reference-box">
        <span class="pdf-label">Numéro de facture :</span>
        {{ invoiceNumber }}
    </div>

{% endblock %}

{% block pdf_content %}

    <table class="pdf-two-columns">
        <tr>
            <td class="pdf-left">

                <div class="pdf-section">
                    <h2 class="pdf-section-title">Facturation</h2>

                    <div class="pdf-row">
                        <span class="pdf-label">Date :</span>
                        {{ preOrder.paidAt|date('d/m/Y H:i') }}
                    </div>

                    <div class="pdf-row">
                        <span class="pdf-label">Statut :</span>
                        Facture acquittée
                    </div>
                </div>

            </td>

            <td class="pdf-right">

                <div class="pdf-section">
                    <h2 class="pdf-section-title">Client</h2>

                    <div class="pdf-row">
                        <span class="pdf-label">Contact :</span>
                        {{ preOrder.user.firstname }} {{ preOrder.user.lastname }}
                    </div>

                    <div class="pdf-row">
                        <span class="pdf-label">Adresse :</span>
                        {{ preOrder.user.address ?: 'Non renseignée' }}
                    </div>

                    <div class="pdf-row">
                        <span class="pdf-label">Code postal :</span>
                        {{ preOrder.user.zipcode ?: 'Non renseigné' }}
                    </div>

                    <div class="pdf-row">
                        <span class="pdf-label">Ville :</span>
                        {{ preOrder.user.city ?: 'Non renseignée' }}
                    </div>

                    <div class="pdf-row">
                        <span class="pdf-label">E-mail :</span>
                        {{ preOrder.user.email }}
                    </div>
                </div>

            </td>
        </tr>
    </table>

    <table class="pdf-table">

        <thead>
        <tr>
            <th>Article</th>
            <th>Diamètre</th>
            <th>Quantité</th>
            <th>Prix unitaire</th>
            <th>Total</th>
        </tr>
        </thead>

        <tbody>
        {% for item in preOrder.preOrderItems %}
            <tr>
                <td>{{ item.article.name }}</td>

                <td>
                    {% if item.diameter %}
                        {{ item.diameter.value }} mm
                    {% else %}
                        —
                    {% endif %}
                </td>

                <td>{{ item.quantity }}</td>

                <td>
                    {% if item.unitPrice > 0 %}
                        {{ item.unitPrice|number_format(2, ',', ' ') }} €
                    {% else %}
                        Nous contacter
                    {% endif %}
                </td>

                <td>
                    {% if item.totalPrice > 0 %}
                        {{ item.totalPrice|number_format(2, ',', ' ') }} €
                    {% else %}
                        Prix à définir
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>

    </table>

    {% if preOrder.totalAmount > 0 %}
        <div class="pdf-total">
            Total : {{ preOrder.totalAmount|number_format(2, ',', ' ') }} €
        </div>
    {% else %}
        <div class="pdf-total">
            Total : Prix à définir avec l'association
        </div>
    {% endif %}

    <div class="pdf-section pdf-payment-section">
        <h2 class="pdf-section-title">Paiement</h2>

        <div class="pdf-row">
            <span class="pdf-label">Mode de paiement :</span>
            HelloAsso / Carte bancaire
        </div>

        <div class="pdf-row">
            <span class="pdf-label">Date de règlement :</span>
            {{ preOrder.paidAt|date('d/m/Y H:i') }}
        </div>
    </div>

{% endblock %}

{% block pdf_footer %}
    Facture générée automatiquement par SOS Faons Bretagne.<br>
    Association loi 1901 – SOS Faons Bretagne – 11 Louvel, 35140 Gosné.
{% endblock %}
