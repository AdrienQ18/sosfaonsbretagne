{% extends 'pdf/_base_pdf.html.twig' %}

{% block pdf_title %}
    Reçu fiscal - {{ receiptNumber }}
{% endblock %}

{% block pdf_header %}

    <img class="pdf-logo" src="{{ logoPath }}" alt="Logo SOS Faons Bretagne">

    <h1 class="pdf-title">Attestation de don</h1>
    <p class="pdf-subtitle">Reçu fiscal</p>

    <div class="pdf-reference-box">
        <span class="pdf-label">Numéro du reçu fiscal :</span>
        {{ receiptNumber }}
    </div>

{% endblock %}

{% block pdf_content %}

    {% if donation.donorType.value == 'entreprise' %}
        <p class="pdf-legal-reference">
            Article 238 bis du Code général des impôts
        </p>
    {% else %}
        <p class="pdf-legal-reference">
            Article 200 du Code général des impôts
        </p>
    {% endif %}

    <div class="pdf-section">
        <h2 class="pdf-section-title">Organisme bénéficiaire</h2>

        <div class="pdf-row"><span class="pdf-label">Association :</span> SOS Faons Bretagne</div>
        <div class="pdf-row"><span class="pdf-label">Nature de l'organisme :</span> Association loi 1901</div>
        <div class="pdf-row"><span class="pdf-label">Type :</span> Œuvre ou organisme d'intérêt général</div>
        <div class="pdf-row"><span class="pdf-label">Famille :</span> Environnement, cadre de vie</div>
        <div class="pdf-row">
            <span class="pdf-label">Objet :</span>
            Sauver des faons à l'aide d'un drone équipé d'une caméra thermique et évacuer les animaux avant le passage des faucheuses.
        </div>
        <div class="pdf-row"><span class="pdf-label">SIRET :</span> 98764426700013</div>
        <div class="pdf-row"><span class="pdf-label">Adresse :</span> 11 Louvel, 35140 Gosné</div>
        <div class="pdf-row"><span class="pdf-label">Téléphone :</span> 02 02 02 02 02</div>
        <div class="pdf-row"><span class="pdf-label">E-mail :</span> email@sosfaonsbretagne.fr</div>
    </div>

    <table class="pdf-two-columns">
        <tr>
            <td class="pdf-left">
                <div class="pdf-section">

                    {% if donation.donorType.value == 'entreprise' %}
                        <h2 class="pdf-section-title">Entreprise donatrice</h2>

                        <div class="pdf-row"><span class="pdf-label">Entreprise :</span> {{ donation.companyName }}</div>
                        <div class="pdf-row"><span class="pdf-label">SIRET :</span> {{ donation.companySiret }}</div>
                        <div class="pdf-row"><span class="pdf-label">Contact :</span> {{ donation.firstname }} {{ donation.lastname }}</div>
                    {% else %}
                        <h2 class="pdf-section-title">Donateur</h2>

                        <div class="pdf-row"><span class="pdf-label">Nom :</span> {{ donation.lastname }}</div>
                        <div class="pdf-row"><span class="pdf-label">Prénom :</span> {{ donation.firstname }}</div>
                    {% endif %}

                    <div class="pdf-row"><span class="pdf-label">Adresse :</span> {{ donation.address }}</div>
                    <div class="pdf-row"><span class="pdf-label">Code postal :</span> {{ donation.zipcode }}</div>
                    <div class="pdf-row"><span class="pdf-label">Ville :</span> {{ donation.city }}</div>
                    <div class="pdf-row"><span class="pdf-label">E-mail :</span> {{ donation.email }}</div>

                </div>
            </td>

            <td class="pdf-right">
                <div class="pdf-section">
                    <h2 class="pdf-section-title">Don effectué</h2>

                    <div class="pdf-row"><span class="pdf-label">Montant du don :</span> {{ donation.amount|number_format(2, ',', ' ') }} €</div>
                    <div class="pdf-row"><span class="pdf-label">Date du don :</span> {{ donation.donationDate|date('d/m/Y H:i:s') }}</div>
                    <div class="pdf-row"><span class="pdf-label">Forme du don :</span> Don manuel</div>
                    <div class="pdf-row"><span class="pdf-label">Nature du don :</span> Paiement en ligne HelloAsso</div>
                    <div class="pdf-row"><span class="pdf-label">Mode de paiement :</span> Carte bancaire / HelloAsso</div>

                    {% if donation.donorType.value == 'entreprise' %}
                        <div class="pdf-row"><span class="pdf-label">Type de donateur :</span> Entreprise</div>
                        <div class="pdf-row"><span class="pdf-label">Réduction fiscale :</span> 60 %</div>
                    {% else %}
                        <div class="pdf-row"><span class="pdf-label">Type de donateur :</span> Particulier</div>
                        <div class="pdf-row"><span class="pdf-label">Réduction fiscale :</span> 66 %</div>
                    {% endif %}
                </div>
            </td>
        </tr>
    </table>

    <div class="pdf-note">
        {% if donation.donorType.value == 'entreprise' %}
            <p>
                Le bénéficiaire certifie sur l'honneur que les dons et versements qu'il reçoit ouvrent droit à la réduction
                d'impôt prévue à l'article 238 bis du Code général des impôts.
            </p>

            <p>
                Entreprise : vous pouvez bénéficier d'une réduction d'impôt égale à 60 % du montant du don,
                dans les limites prévues par la réglementation en vigueur.
            </p>
        {% else %}
            <p>
                Le bénéficiaire certifie sur l'honneur que les dons et versements qu'il reçoit ouvrent droit à la réduction
                d'impôt prévue à l'article 200 du Code général des impôts.
            </p>

            <p>
                Particulier : vous pouvez bénéficier d'une réduction d'impôt égale à 66 % du montant de votre don,
                dans la limite de 20 % de votre revenu imposable.
            </p>
        {% endif %}

        <table class="pdf-signature-table">
            <tr>
                <td>
                    <p>
                        Document généré automatiquement.
                        À conserver par le donateur pour ses démarches administratives.
                    </p>
                </td>

                <td class="pdf-signature-cell">
                    <p>Fait à Gosné, le {{ "now"|date('d/m/Y') }}</p>

                    <img src="{{ signaturePath }}" alt="Signature">

                    <p><strong>Trésorier</strong></p>
                </td>
            </tr>
        </table>

{% endblock %}

{% block pdf_footer %}
    Conformément au Règlement Général sur la Protection des Données, vous disposez d'un droit d'accès,
    de rectification, d'opposition et de suppression des données vous concernant.
    Pour exercer vos droits, vous pouvez nous adresser votre demande par mail à l'adresse
    contact@sosfaonsbretagne.fr. Ces informations sont réservées à l'usage exclusif de SOS Faons Bretagne.
{% endblock %}
    </div>
