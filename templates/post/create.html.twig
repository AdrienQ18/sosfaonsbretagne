{% extends 'base.html.twig' %}

{% block title %}
    {% if isEdit|default(false) %}Modifier un post{% else %}Créer un post{% endif %} | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Interface privée de création et modification des actualités SOS Faons Bretagne.
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <section class="ui-page ui-page--radial">

        <div class="ui-container ui-container--900">

            <header class="ui-header ui-header--center">

                <h1>
                    {% if isEdit|default(false) %}
                        Modification d'un post
                    {% else %}
                        Création d'un post
                    {% endif %}
                </h1>

                <p>
                    {% if isEdit|default(false) %}
                        Modifiez l'article, l'événement ou l'actualité sélectionné.
                    {% else %}
                        Créez un nouvel article, événement ou actualité
                        qui sera publié sur le site SOS Faons Bretagne.
                    {% endif %}
                </p>

            </header>

            <div class="event-create-card ui-card">

                {{ form_start(eventForm, {
                    attr: {
                        class: 'event-create-form',
                        novalidate: 'novalidate'
                    }
                }) }}

                {{ form_errors(eventForm) }}

                <div class="ui-form-row ui-form-row--relaxed">

                    <div class="event-form-group ui-field">
                        {{ form_label(eventForm.type) }}
                        {{ form_widget(eventForm.type) }}
                        {{ form_errors(eventForm.type) }}
                    </div>

                    <div class="event-form-group ui-field">
                        {{ form_label(eventForm.eventDate) }}
                        {{ form_widget(eventForm.eventDate) }}
                        {{ form_errors(eventForm.eventDate) }}
                    </div>

                </div>

                <div class="event-form-group ui-field">
                    {{ form_label(eventForm.name) }}
                    {{ form_widget(eventForm.name) }}
                    {{ form_errors(eventForm.name) }}
                </div>

                <div class="event-form-group ui-field">
                    {{ form_label(eventForm.localisation) }}
                    {{ form_widget(eventForm.localisation) }}
                    {{ form_errors(eventForm.localisation) }}
                </div>

                <div class="ui-form-row ui-form-row--relaxed">

                    <div class="event-form-group ui-field">
                        {{ form_label(eventForm.nbParticipant) }}
                        {{ form_widget(eventForm.nbParticipant) }}
                        {{ form_errors(eventForm.nbParticipant) }}
                    </div>

                </div>

                <div class="event-form-group ui-field">

                    {{ form_label(eventForm.description) }}
                    {{ form_widget(eventForm.description) }}
                    {{ form_errors(eventForm.description) }}

                </div>

                <div class="event-form-group ui-field ui-file-group">

                    {{ form_label(eventForm.image) }}

                    {{ form_widget(eventForm.image, {
                        attr: {
                            class: 'event-file-input',
                            accept: 'image/*'
                        }
                    }) }}

                    {{ form_errors(eventForm.image) }}

                </div>

                <div class="event-actions">

                    <button
                        type="submit"
                        name="action"
                        value="enregistrer"
                        class="event-button event-button-secondary ui-button ui-button--secondary"
                        aria-label="Enregistrer le post comme brouillon"
                    >
                        Enregistrer comme brouillon
                    </button>

                    <button
                        type="submit"
                        name="action"
                        value="publier"
                        class="event-button event-button-primary ui-button ui-button--primary"
                        aria-label="Publier le post"
                    >
                        Publier
                    </button>

                </div>

                {{ form_end(eventForm) }}

            </div>

        </div>

    </section>

{% endblock %}
