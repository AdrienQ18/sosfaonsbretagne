{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Confirmation de votre adresse email
{% endblock %}

{% block email_header %}
    <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3;">
        Confirmez votre adresse email
    </h1>

    <p style="margin:8px 0 0 0; color:#ffffff;">
        SOS Faons Bretagne
    </p>
{% endblock %}

{% block email_content %}

    <p style="margin:0 0 18px 0;">
        Bonjour,
    </p>

    <p style="margin:0 0 18px 0;">
        Merci pour votre inscription sur
        <strong>SOS Faons Bretagne</strong>.
    </p>

    <p style="margin:0 0 24px 0;">
        Pour activer votre compte et accéder à l'ensemble des fonctionnalités du site,
        veuillez confirmer votre adresse email en cliquant sur le bouton ci-dessous :
    </p>

    <p style="margin:0 0 26px 0; text-align:center;">
        <a
            href="{{ signedUrl|raw }}"
            style="display:inline-block; background-color:#1b4a3a; color:#ffffff; padding:14px 28px; text-decoration:none; font-weight:bold; border-radius:8px;"
        >
            Confirmer mon adresse email
        </a>
    </p>

    <div
        style="
            background-color:#f4efe8;
            border-left:4px solid #6e8e64;
            padding:16px;
            margin:20px 0;
            color:#2b2b2b;
            line-height:1.6;
        "
    >
        Ce lien expirera dans
        <strong>
            {{ expiresAtMessageKey|trans(
                expiresAtMessageData,
                'VerifyEmailBundle'
            ) }}
        </strong>.
    </div>

    <p style="margin:20px 0 0 0;">
        Si vous n'êtes pas à l'origine de cette inscription,
        vous pouvez ignorer cet email en toute sécurité.
    </p>

{% endblock %}

{% block email_footer %}
    Cet email a été envoyé automatiquement par SOS Faons Bretagne.<br>
    Merci de ne pas répondre directement à ce message.
{% endblock %}
