{% extends 'base.html.twig' %}

{% block title %}
    Email de réinitialisation envoyé | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Un email de réinitialisation de mot de passe a été envoyé si un compte correspondant existe.
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <section class="reset-page">
        <div class="reset-container">
            <div class="reset-card">

                <h1>Email envoyé</h1>

                <p>
                    Si un compte correspondant à cette adresse email existe,
                    un email contenant un lien de réinitialisation vient d’être envoyé.
                </p>

                <div class="reset-info-box">
                    Ce lien expirera dans
                    <strong>
                        {{ resetToken.expirationMessageKey|trans(
                            resetToken.expirationMessageData,
                            'ResetPasswordBundle'
                        ) }}
                    </strong>.
                </div>

                <p>
                    Si vous ne recevez pas l’email dans quelques minutes,
                    pensez à vérifier vos spams ou courriers indésirables.
                </p>

                <div class="reset-actions">
                    <a
                        href="{{ path('app_forgot_password_request') }}"
                        class="reset-button"
                    >
                        Réessayer
                    </a>

                    <a
                        href="{{ path('app_login') }}"
                        class="reset-back-link"
                    >
                        Retour à la connexion
                    </a>
                </div>

            </div>
        </div>
    </section>

{% endblock %}
