```twig
{% extends 'base.html.twig' %}

{% block title %}
    Email de réinitialisation envoyé | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Un email de réinitialisation de mot de passe a été envoyé si un compte correspondant existe.
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <section class="auth-page">

        <div class="reset-password-container">

            <div class="reset-password-card">

                <img
                    src="{{ asset('images/LogoSOSFaonsBretagne.svg') }}"
                    alt="Logo SOS Faons Bretagne"
                    class="reset-password-logo"
                    loading="lazy"
                    width="120"
                    height="120"
                >

                <h1>Email envoyé</h1>

                <p>
                    Si un compte correspondant à cette adresse email existe,
                    un email contenant un lien de réinitialisation vient d’être envoyé.
                </p>

                <p>
                    Ce lien expirera dans
                    <strong>
                        {{ resetToken.expirationMessageKey|trans(
                            resetToken.expirationMessageData,
                            'ResetPasswordBundle'
                        ) }}
                    </strong>.
                </p>

                <p>
                    Si vous ne recevez pas l’email dans quelques minutes,
                    pensez à vérifier vos spams ou courriers indésirables.
                </p>

                <div class="reset-password-actions">

                    <a
                        href="{{ path('app_forgot_password_request') }}"
                        class="reset-password-button"
                        aria-label="Réessayer la demande de réinitialisation de mot de passe"
                    >
                        Réessayer
                    </a>

                    <a
                        href="{{ path('app_login') }}"
                        class="back-login-link"
                        aria-label="Retourner à la page de connexion"
                    >
                        Retour à la connexion
                    </a>

                </div>

            </div>

        </div>

    </section>

{% endblock %}
```
