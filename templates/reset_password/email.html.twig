{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Réinitialisation de votre mot de passe
{% endblock %}

{% block email_header %}
    <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3;">
        Mot de passe oublié
    </h1>

    <p style="margin:8px 0 0 0; color:#ffffff;">
        SOS Faons Bretagne
    </p>
{% endblock %}

{% block email_content %}

    <p style="margin:0 0 18px 0;">
        Bonjour,
    </p>

    <p style="margin:0 0 18px 0;">
        Vous avez demandé la réinitialisation du mot de passe associé à votre compte
        <strong>SOS Faons Bretagne</strong>.
    </p>

    <p style="margin:0 0 24px 0;">
        Cliquez sur le bouton ci-dessous pour définir un nouveau mot de passe sécurisé :
    </p>

    <p style="margin:0 0 26px 0; text-align:center;">
        <a
            href="{{ url('app_reset_password', {token: resetToken.token}) }}"
            style="display:inline-block; background-color:#1b4a3a; color:#ffffff; padding:14px 28px; text-decoration:none; font-weight:bold; border-radius:8px;"
        >
            Réinitialiser mon mot de passe
        </a>
    </p>

    <div
        style="
            background-color:#f4efe8;
            border-left:4px solid #6e8e64;
            padding:16px;
            margin:20px 0;
            color:#2b2b2b;
            line-height:1.6;
        "
    >
        Ce lien expirera dans
        <strong>
            {{ resetToken.expirationMessageKey|trans(
                resetToken.expirationMessageData,
                'ResetPasswordBundle'
            ) }}
        </strong>.
    </div>

    <p style="margin:20px 0 0 0;">
        Si vous n’êtes pas à l’origine de cette demande, vous pouvez ignorer cet email.
    </p>

{% endblock %}
