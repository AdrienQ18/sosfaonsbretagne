{% extends 'base.html.twig' %}

{% block title %}
    Nouveau mot de passe
{% endblock %}

{% block body %}

    <section class="auth-page">
        <div class="reset-password-container">

            <div class="reset-password-card">

                <img
                    src="{{ asset('images/LogoSOSFaonsBretagne.svg') }}"
                    alt="Logo SOS Faons Bretagne"
                    class="reset-password-logo"
                >

                <h1>Nouveau mot de passe</h1>

                <p>
                    Choisissez un nouveau mot de passe sécurisé
                    pour votre compte.
                </p>

                {{ form_start(resetForm, {
                    attr: {
                        novalidate: 'novalidate',
                        class: 'reset-password-form'
                    }
                }) }}

                <div class="form-group">
                    {{ form_label(resetForm.plainPassword.first) }}

                    <div class="password-wrapper">
                        {{ form_widget(resetForm.plainPassword.first, {
                            attr: {
                                class: 'password-input',
                                placeholder: 'Votre nouveau mot de passe'
                            }
                        }) }}

                        <button
                            type="button"
                            class="toggle-password"
                            data-target="{{ resetForm.plainPassword.first.vars.id }}"
                            aria-label="Afficher le mot de passe"
                        >
                            <img src="{{ asset('images/icons/eye-open.png') }}" alt="Afficher le mot de passe">
                        </button>
                    </div>

                    {{ form_errors(resetForm.plainPassword.first) }}
                </div>

                <div class="form-group">
                    {{ form_label(resetForm.plainPassword.second) }}

                    <div class="password-wrapper">
                        {{ form_widget(resetForm.plainPassword.second, {
                            attr: {
                                class: 'password-input',
                                placeholder: 'Confirmez votre mot de passe'
                            }
                        }) }}

                        <button
                            type="button"
                            class="toggle-password"
                            data-target="{{ resetForm.plainPassword.second.vars.id }}"
                            aria-label="Afficher le mot de passe"
                        >
                            <img src="{{ asset('images/icons/eye-open.png') }}" alt="Afficher le mot de passe">
                        </button>
                    </div>

                    {{ form_errors(resetForm.plainPassword.second) }}
                </div>

                {{ form_errors(resetForm.plainPassword) }}
                <p id="password-match-message" class="password-match-message"></p>
                <button type="submit">
                    Réinitialiser le mot de passe
                </button>

                {{ form_end(resetForm) }}

                <a href="{{ path('app_login') }}" class="back-login-link">
                    Retour à la connexion
                </a>

            </div>

        </div>
    </section>

{% endblock %}

{% block extraJs %}

    <script>
        document.addEventListener('DOMContentLoaded', () => {

            const togglePasswordButtons = document.querySelectorAll('.toggle-password');

            togglePasswordButtons.forEach((button) => {

                button.addEventListener('click', () => {

                    const targetId = button.dataset.target;
                    const input = document.getElementById(targetId);
                    const image = button.querySelector('img');

                    if (!input || !image) return;

                    if (input.type === 'password') {

                        input.type = 'text';

                        image.src = "{{ asset('images/icons/eye-close.png') }}";
                        image.alt = 'Masquer le mot de passe';

                        button.setAttribute(
                            'aria-label',
                            'Masquer le mot de passe'
                        );

                    } else {

                        input.type = 'password';

                        image.src = "{{ asset('images/icons/eye-open.png') }}";
                        image.alt = 'Afficher le mot de passe';

                        button.setAttribute(
                            'aria-label',
                            'Afficher le mot de passe'
                        );

                    }

                });

            });

        });
        const firstPassword = document.getElementById(
            '{{ resetForm.plainPassword.first.vars.id }}'
        );

        const secondPassword = document.getElementById(
            '{{ resetForm.plainPassword.second.vars.id }}'
        );

        const passwordMessage = document.getElementById(
            'password-match-message'
        );

        function checkPasswordsMatch() {

            if (secondPassword.value.length === 0) {

                passwordMessage.textContent = '';
                return;

            }

            if (firstPassword.value === secondPassword.value) {

                passwordMessage.textContent = 'Les mots de passe correspondent.';
                passwordMessage.style.color = '#2e7d32';

            } else {

                passwordMessage.textContent = 'Les mots de passe ne correspondent pas.';
                passwordMessage.style.color = '#c62828';

            }

        }

        firstPassword.addEventListener('input', checkPasswordsMatch);
        secondPassword.addEventListener('input', checkPasswordsMatch);
    </script>

{% endblock %}

