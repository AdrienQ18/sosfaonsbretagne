{% extends 'base.html.twig' %}

{% block title %}
    Nouveau mot de passe | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Créez un nouveau mot de passe sécurisé pour votre compte SOS Faons Bretagne.
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <section class="reset-page">
        <div class="reset-container">
            <div class="reset-card">

                <h1>Nouveau mot de passe</h1>

                <p>
                    Choisissez un nouveau mot de passe sécurisé
                    pour votre compte.
                </p>

                {{ form_start(resetForm, {
                    attr: {
                        novalidate: 'novalidate',
                        class: 'reset-form'
                    }
                }) }}

                <div class="reset-form-group">
                    {{ form_label(resetForm.plainPassword.first) }}

                    <div class="reset-password-wrapper">
                        {{ form_widget(resetForm.plainPassword.first, {
                            attr: {
                                class: 'password-input',
                                placeholder: 'Votre nouveau mot de passe',
                                autocomplete: 'new-password'
                            }
                        }) }}

                        <button
                            type="button"
                            class="reset-toggle-password"
                            data-target="{{ resetForm.plainPassword.first.vars.id }}"
                            aria-label="Afficher le mot de passe"
                            aria-pressed="false"
                        >
                            <img
                                src="{{ asset('images/icones/eye-open.png') }}"
                                alt=""
                                aria-hidden="true"
                            >
                        </button>
                    </div>

                    {{ form_errors(resetForm.plainPassword.first) }}
                </div>

                <div class="reset-form-group">
                    {{ form_label(resetForm.plainPassword.second) }}

                    <div class="reset-password-wrapper">
                        {{ form_widget(resetForm.plainPassword.second, {
                            attr: {
                                class: 'password-input',
                                placeholder: 'Confirmez votre mot de passe',
                                autocomplete: 'new-password'
                            }
                        }) }}

                        <button
                            type="button"
                            class="reset-toggle-password"
                            data-target="{{ resetForm.plainPassword.second.vars.id }}"
                            aria-label="Afficher le mot de passe"
                            aria-pressed="false"
                        >
                            <img
                                src="{{ asset('images/icones/eye-open.png') }}"
                                alt=""
                                aria-hidden="true"
                            >
                        </button>
                    </div>

                    {{ form_errors(resetForm.plainPassword.second) }}
                </div>

                {{ form_errors(resetForm.plainPassword) }}

                <p
                    id="password-match-message"
                    class="password-match-message"
                    aria-live="polite"
                ></p>

                <button type="submit" class="reset-submit-button">
                    Réinitialiser le mot de passe
                </button>

                {{ form_end(resetForm) }}

                <a href="{{ path('app_login') }}" class="reset-back-link">
                    Retour à la connexion
                </a>

            </div>
        </div>
    </section>

{% endblock %}

{% block extraJs %}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const togglePasswordButtons = document.querySelectorAll('.reset-toggle-password');

            togglePasswordButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    const targetId = button.dataset.target;
                    const input = document.getElementById(targetId);
                    const image = button.querySelector('img');

                    if (!input || !image) {
                        return;
                    }

                    const isHidden = input.type === 'password';

                    input.type = isHidden ? 'text' : 'password';

                    image.src = isHidden
                        ? "{{ asset('images/icones/eye-close.png') }}"
                        : "{{ asset('images/icones/eye-open.png') }}";

                    button.setAttribute(
                        'aria-label',
                        isHidden ? 'Masquer le mot de passe' : 'Afficher le mot de passe'
                    );

                    button.setAttribute(
                        'aria-pressed',
                        isHidden ? 'true' : 'false'
                    );
                });
            });

            const firstPassword = document.getElementById(
                '{{ resetForm.plainPassword.first.vars.id }}'
            );

            const secondPassword = document.getElementById(
                '{{ resetForm.plainPassword.second.vars.id }}'
            );

            const passwordMessage = document.getElementById(
                'password-match-message'
            );

            if (!firstPassword || !secondPassword || !passwordMessage) {
                return;
            }

            function checkPasswordsMatch() {
                if (secondPassword.value.length === 0) {
                    passwordMessage.textContent = '';
                    passwordMessage.classList.remove('success');
                    passwordMessage.classList.remove('error');

                    return;
                }

                if (firstPassword.value === secondPassword.value) {
                    passwordMessage.textContent = 'Les mots de passe correspondent.';
                    passwordMessage.classList.remove('error');
                    passwordMessage.classList.add('success');
                } else {
                    passwordMessage.textContent = 'Les mots de passe ne correspondent pas.';
                    passwordMessage.classList.remove('success');
                    passwordMessage.classList.add('error');
                }
            }

            firstPassword.addEventListener('input', checkPasswordsMatch);
            secondPassword.addEventListener('input', checkPasswordsMatch);
        });
    </script>
{% endblock %}
