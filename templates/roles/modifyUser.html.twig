{% extends 'base.html.twig' %}

{% block title %}
    Modifier un utilisateur | SOS Faons Bretagne
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <section class="admin-user-form-page">
        <div class="admin-user-form-container">
            <div class="admin-user-form-card">
                <header class="admin-user-form-header">
                    <h1>Modifier un utilisateur</h1>
                    <p>
                        Modifiez les informations du compte utilisateur.
                    </p>
                </header>
                {{ form_start(formUser, {
                    attr: {
                        class: 'admin-user-form',
                        novalidate: 'novalidate'
                    }
                }) }}
                <div class="admin-user-form-row">
                    <div class="admin-user-form-group">
                        {{ form_label(formUser.firstname) }}
                        {{ form_widget(formUser.firstname) }}
                        {{ form_errors(formUser.firstname) }}
                    </div>
                    <div class="admin-user-form-group">
                        {{ form_label(formUser.lastname) }}
                        {{ form_widget(formUser.lastname) }}
                        {{ form_errors(formUser.lastname) }}
                    </div>
                </div>
                <div class="admin-user-form-row">
                    <div class="admin-user-form-group">
                        {{ form_label(formUser.email) }}
                        {{ form_widget(formUser.email) }}
                        {{ form_errors(formUser.email) }}
                    </div>
                    <div class="admin-user-form-group">
                        {{ form_label(formUser.phone) }}
                        {{ form_widget(formUser.phone) }}
                        {{ form_errors(formUser.phone) }}
                    </div>
                </div>
                <div class="admin-user-form-group">
                    {{ form_label(formUser.address) }}
                    {{ form_widget(formUser.address) }}
                    {{ form_errors(formUser.address) }}
                </div>
                <div class="admin-user-form-row">
                    <div class="admin-user-form-group">
                        {{ form_label(formUser.city) }}
                        {{ form_widget(formUser.city) }}
                        {{ form_errors(formUser.city) }}
                    </div>
                    <div class="admin-user-form-group">
                        {{ form_label(formUser.zipcode) }}
                        {{ form_widget(formUser.zipcode) }}
                        {{ form_errors(formUser.zipcode) }}
                    </div>
                </div>
                <div class="admin-user-form-row">
                    <div class="admin-user-form-group">
                        {{ form_label(formUser.birthday) }}
                        {{ form_widget(formUser.birthday) }}
                        {{ form_errors(formUser.birthday) }}
                    </div>
                    <div class="admin-user-form-group">
                        {{ form_label(formUser.userRole) }}
                        {{ form_widget(formUser.userRole) }}
                        {{ form_errors(formUser.userRole) }}
                    </div>
                </div>
                <div class="admin-user-form-single-checkbox">
                    {{ form_label(formUser.actif) }}
                    {{ form_widget(formUser.actif) }}
                    {{ form_errors(formUser.actif) }}
                </div>
                <div class="admin-user-form-choice-group">
                    {{ form_label(formUser.availabilitys) }}
                    {{ form_widget(formUser.availabilitys) }}
                    {{ form_errors(formUser.availabilitys) }}
                </div>
                {% if formUser.roles is defined %}
                    <div class="admin-user-form-choice-group">
                        {{ form_label(formUser.roles) }}
                        {{ form_widget(formUser.roles) }}
                        {{ form_errors(formUser.roles) }}
                    </div>
                {% endif %}
                <div class="admin-user-form-actions">
                    <a
                        href="{{ path('admin_userList') }}"
                        class="admin-user-form-back-button"
                        aria-label="Retour à la liste des utilisateurs"
                    >
                        Retour
                    </a>

                    <button
                        type="submit"
                        class="admin-user-form-submit-button"
                        aria-label="Modifier l'utilisateur"
                    >
                        Modifier
                    </button>
                </div>
                {{ form_end(formUser) }}
            </div>
        </div>
    </section>

{% endblock %}
