{% extends 'base.html.twig' %}

{% block title %}
    Connexion / Inscription | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Connectez-vous ou créez votre compte SOS Faons Bretagne pour accéder à votre espace personnel.
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <section class="login-page">
        <div
            class="login-container {% if mode == 'register' %}right-panel-active{% endif %}"
            id="authContainer"
        >

            <div class="login-form-container login-signin-container">
                <form method="post" action="{{ path('app_login') }}" novalidate>
                    <h1>Connexion</h1>

                    {% if error %}
                        <div class="alert alert-danger">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <label for="inputEmail" class="sr-only">
                        Adresse email
                    </label>

                    <input
                        type="email"
                        value="{{ last_username }}"
                        name="email"
                        id="inputEmail"
                        placeholder="Adresse email"
                        autocomplete="email"
                        autocapitalize="off"
                        spellcheck="false"
                        required
                    >

                    <div class="login-password-wrapper">
                        <label for="inputPassword" class="sr-only">
                            Mot de passe
                        </label>

                        <input
                            type="password"
                            name="password"
                            id="inputPassword"
                            placeholder="Mot de passe"
                            autocomplete="current-password"
                            spellcheck="false"
                            required
                        >

                        <button
                            type="button"
                            class="login-toggle-password"
                            data-target="inputPassword"
                            data-eye-open="{{ asset('images/icones/eye-open.png') }}"
                            data-eye-close="{{ asset('images/icones/eye-close.png') }}"
                            aria-label="Afficher le mot de passe"
                            aria-pressed="false"
                        >
                            <img
                                src="{{ asset('images/icones/eye-open.png') }}"
                                alt=""
                                aria-hidden="true"
                            >
                        </button>
                    </div>

                    <input
                        type="hidden"
                        name="_csrf_token"
                        value="{{ csrf_token('authenticate') }}"
                    >

                    <label class="login-remember-me">
                        <input type="checkbox" name="_remember_me">
                        Se souvenir de moi
                    </label>

                    <a
                        href="{{ path('app_forgot_password_request') }}"
                        class="login-forgot-password"
                    >
                        Mot de passe oublié ?
                    </a>

                    <button type="submit">
                        Se connecter
                    </button>
                </form>
            </div>

            <div class="login-form-container login-signup-container">
                <div class="login-register-scroll">
                    <h1>Créer un compte</h1>

                    {{ form_start(formRegister, {
                        action: path('app_register'),
                        attr: {
                            novalidate: 'novalidate'
                        }
                    }) }}

                    <div class="login-form-group">
                        {{ form_label(formRegister.email) }}
                        {{ form_widget(formRegister.email) }}
                        {{ form_errors(formRegister.email) }}
                    </div>

                    <div class="login-form-group">
                        {{ form_label(formRegister.plainPassword) }}

                        <div class="login-password-wrapper">
                            {{ form_widget(formRegister.plainPassword) }}

                            <button
                                type="button"
                                class="login-toggle-password"
                                data-target="{{ formRegister.plainPassword.vars.id }}"
                                data-eye-open="{{ asset('images/icones/eye-open.png') }}"
                                data-eye-close="{{ asset('images/icones/eye-close.png') }}"
                                aria-label="Afficher le mot de passe"
                                aria-pressed="false"
                            >
                                <img
                                    src="{{ asset('images/icones/eye-open.png') }}"
                                    alt=""
                                    aria-hidden="true"
                                >
                            </button>
                        </div>

                        <small class="login-form-help">
                            Le mot de passe doit contenir au minimum 12 caractères,
                            une majuscule, une minuscule, un chiffre et un caractère spécial.
                        </small>

                        <p id="password-strength" class="login-password-strength"></p>

                        {{ form_errors(formRegister.plainPassword) }}
                    </div>

                    <div class="login-form-group">
                        {{ form_label(formRegister.lastname) }}
                        {{ form_widget(formRegister.lastname) }}
                        {{ form_errors(formRegister.lastname) }}
                    </div>

                    <div class="login-form-group">
                        {{ form_label(formRegister.firstname) }}
                        {{ form_widget(formRegister.firstname) }}
                        {{ form_errors(formRegister.firstname) }}
                    </div>

                    <div class="login-form-group">
                        {{ form_label(formRegister.phone) }}
                        {{ form_widget(formRegister.phone) }}
                        {{ form_errors(formRegister.phone) }}
                    </div>

                    <div class="login-form-group">
                        {{ form_label(formRegister.address) }}
                        {{ form_widget(formRegister.address) }}
                        {{ form_errors(formRegister.address) }}
                    </div>

                    <div class="login-form-group">
                        {{ form_label(formRegister.city) }}
                        {{ form_widget(formRegister.city) }}
                        {{ form_errors(formRegister.city) }}
                    </div>

                    <div class="login-form-group">
                        {{ form_label(formRegister.zipcode) }}
                        {{ form_widget(formRegister.zipcode) }}
                        {{ form_errors(formRegister.zipcode) }}
                    </div>

                    <div class="login-form-group">
                        {{ form_label(formRegister.birthday) }}
                        {{ form_widget(formRegister.birthday) }}
                        {{ form_errors(formRegister.birthday) }}
                    </div>

                    <div class="login-form-group">
                        <div class="login-form-check">
                            {{ form_label(formRegister.benevole) }}
                            {{ form_widget(formRegister.benevole) }}
                        </div>

                        {{ form_errors(formRegister.benevole) }}
                    </div>

                    <div id="volunteer-roles" style="display: none;">
                        <div class="login-form-group login-availability-group">
                            {{ form_label(formRegister.availabilitys) }}

                            <div class="login-availability-options">
                                {{ form_widget(formRegister.availabilitys) }}
                            </div>

                            {{ form_errors(formRegister.availabilitys) }}
                        </div>
                    </div>

                    <div class="login-form-group">
                        <div class="login-form-check">
                            {{ form_label(formRegister.agreeTerms) }}
                            {{ form_widget(formRegister.agreeTerms) }}
                        </div>

                        {{ form_errors(formRegister.agreeTerms) }}
                    </div>

                    <button
                        type="submit"
                        aria-label="Créer un compte SOS Faons Bretagne"
                    >
                        Créer son compte
                    </button>

                    {{ form_end(formRegister) }}
                </div>
            </div>

            <div class="login-overlay-container">
                <div class="login-overlay">

                    <div class="login-overlay-panel login-overlay-left">
                        <div class="login-overlay-top">
                            <img
                                src="{{ asset('images/LogoSOSFaonsBretagne.svg') }}"
                                alt="Logo SOS Faons Bretagne"
                                class="login-logo"
                                loading="lazy"
                                width="120"
                                height="120"
                            >
                        </div>

                        <div class="login-overlay-bottom">
                            <h2>Déjà inscrit ?</h2>
                            <p>Connectez-vous pour accéder à votre espace.</p>

                            <button class="login-ghost-btn" id="signIn" type="button">
                                Se connecter
                            </button>
                        </div>
                    </div>

                    <div class="login-overlay-panel login-overlay-right">
                        <div class="login-overlay-top">
                            <img
                                src="{{ asset('images/LogoSOSFaonsBretagne.svg') }}"
                                alt="Logo SOS Faons Bretagne"
                                class="login-logo"
                                loading="lazy"
                                width="120"
                                height="120"
                            >
                        </div>

                        <div class="login-overlay-bottom">
                            <h2>Bienvenue !</h2>
                            <p>Créez votre compte et rejoignez SOS Faons Bretagne.</p>
                            <button class="login-ghost-btn" id="signUp" type="button">
                                Créer un compte
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>

{% endblock %}
