{% extends 'base.html.twig' %}

{% block title %}
    Administration des articles | SOS Faons Bretagne
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <section class="admin-article-page ui-page">
        <div class="admin-article-container ui-container">

            <header class="admin-article-header ui-admin-header ui-header">
                <div>
                    <h1>Administration des articles</h1>

                    <p>
                        Gérez les articles disponibles dans la boutique solidaire.
                    </p>
                </div>

                <a
                    href="{{ path('admin_article_add') }}"
                    class="admin-article-add-button ui-button ui-button--primary"
                >
                    Ajouter un article
                </a>
            </header>

            <section class="admin-article-grid">
                {% for article in articleList %}
                    <article class="admin-article-card ui-card">

                        <div class="admin-article-image-wrapper">
                            <img
                                src="{{ asset('images/shop/' ~ article.image) }}"
                                alt="{{ article.name }}"
                                class="admin-article-image"
                                loading="lazy"
                            >
                        </div>

                        <div class="admin-article-content">
                            <h2>{{ article.name }}</h2>

                            <p class="admin-article-price">
                                {{ article.price|number_format(2, ',', ' ') }} €
                            </p>

                            <p class="admin-article-description">
                                {{ article.description|nl2br }}
                            </p>

                            <div class="admin-article-actions">
                                <a
                                    href="{{ path('admin_article_update', {id: article.id}) }}"
                                    class="admin-article-edit-button ui-button ui-button--primary"
                                >
                                    Modifier
                                </a>

                                <form
                                    method="post"
                                    action="{{ path('admin_article_delete', {id: article.id}) }}"
                                    onsubmit="return confirm('Voulez-vous vraiment supprimer cet article ?');"
                                >
                                    <input
                                        type="hidden"
                                        name="_token"
                                        value="{{ csrf_token('delete_article_' ~ article.id) }}"
                                    >
                                    <button
                                        type="submit"
                                        class="admin-article-delete-button ui-button ui-button--danger"
                                    >
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </div>

                    </article>
                {% else %}
                    <div class="admin-article-empty ui-empty-state">
                        Aucun article trouvé.
                    </div>
                {% endfor %}
            </section>

        </div>
    </section>

{% endblock %}
