{% extends 'base.html.twig' %}

{% block title %}
    Boutique | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Découvrez la boutique solidaire SOS Faons Bretagne : articles artisanaux disponibles en précommande pour soutenir les actions de l'association.
{% endblock %}

{% block robots %}
    <meta name="robots" content="index, follow">
{% endblock %}

{% block canonical %}
    <link rel="canonical" href="{{ absolute_url(path('shop')) }}">
{% endblock %}

{% block og_title %}
    Boutique | SOS Faons Bretagne
{% endblock %}

{% block og_description %}
    Découvrez la boutique solidaire SOS Faons Bretagne : articles artisanaux disponibles en précommande pour soutenir les actions de l'association.
{% endblock %}

{% block body %}

    <section class="ui-page ui-page--radial">

        <div class="ui-container ui-container--1160">

            <header class="ui-header ui-header--center ui-header--720">

                <h1>Boutique solidaire</h1>

                <p>
                    Toutes nos créations sont fabriquées à la main à partir de bois recyclé et de bois
                    locaux tels que le <span class="strong-text">douglas, le chêne ou le châtaignier.</span> Cette démarche artisanale et
                    écologique nous permet de donner une seconde vie aux matériaux tout en proposant des
                    réalisations durables et respectueuses de l'environnement. Le douglas, le chêne et le
                    châtaignier sont des essences naturellement durables. Riches en composés naturels (tanins
                    pour le chêne et le châtaignier, résines pour le douglas), elles résistent naturellement à
                    l'humidité, aux champignons et aux insectes xylophages. Cette durabilité permet de fabriquer
                    des nichoirs, mangeoires et autres aménagements extérieurs sans traitement chimique, tout en
                    garantissant une longue durée de vie et un impact limité sur l'environnement.
                </p>
                <p>
                    <span class="strong-text">Chaque pièce est unique.</span> Les dimensions indiquées sont données à titre indicatif et
                    peuvent présenter de légères variations de quelques millimètres en raison de la fabrication
                    artisanale et des spécificités naturelles du bois.
                </p>

            </header>

            <div class="boutique-grid">

                {% for article in articleList %}

                    <article class="boutique-card ui-card">

                        <div class="boutique-image-wrapper">

                            <img
                                src="{{ asset('images/shop/' ~ article.image) }}"
                                alt="{{ article.name }}"
                                class="boutique-image js-image-viewer"
                                loading="lazy"
                            >

                        </div>

                        <div class="boutique-content">

                            <div class="boutique-card-header">

                                <h2>{{ article.name }}</h2>
                                <button
                                    type="button"
                                    class="boutique-info-button"
                                    data-modal="boutique-modal-{{ article.id }}"
                                    aria-label="Voir les informations complémentaires sur {{ article.name }}"                                >
                                    ?
                                </button>
                            </div>

                            <span class="boutique-badge">
                                Fabrication artisanale
                            </span>

                            <p class="boutique-price">

                                {% if article.price > 0 %}
                                    {{ article.price|number_format(2, ',', ' ') }} €
                                {% else %}
                                    Contacter l'association
                                {% endif %}

                            </p>

                            <p class="boutique-description">
                                {{ article.description|nl2br }}
                            </p>

                            <form
                                method="post"
                                action="{{ path('cart_add', { id: article.id }) }}"
                                class="boutique-form"
                            >

                                <input
                                    type="hidden"
                                    name="_token"
                                    value="{{ csrf_token('cart_add_' ~ article.id) }}"
                                >

                                {% if article.requiresDiameter %}

                                    <div class="boutique-options">

                                        <span>Diamètre</span>

                                        <div class="boutique-radio-group">

                                            <label>
                                                <input
                                                    type="radio"
                                                    name="diameter"
                                                    value="28"
                                                    required
                                                >
                                                28 mm
                                            </label>

                                            <label>
                                                <input
                                                    type="radio"
                                                    name="diameter"
                                                    value="32"
                                                    required
                                                >
                                                32 mm
                                            </label>

                                        </div>

                                    </div>

                                {% endif %}

                                <label class="boutique-quantity">

                                    <span>Quantité</span>

                                    <input
                                        type="number"
                                        name="quantity"
                                        value="1"
                                        min="1"
                                        inputmode="numeric"
                                        required
                                    >

                                </label>

                                {% if article.price > 0 %}

                                    <button
                                        type="submit"
                                        class="ui-button ui-button--primary ui-button--full ui-button--padded ui-button--caps"
                                    >
                                        Ajouter au panier
                                    </button>

                                {% else %}

                                    <a
                                        href="{{ path('main_contact') }}"
                                        class="boutique-submit-button--contact ui-button ui-button--primary ui-button--full ui-button--padded ui-button--caps"
                                    >
                                        Contacter l'association
                                    </a>

                                {% endif %}

                            </form>

                        </div>

                    </article>

                {% endfor %}

            </div>

        </div>
        <div id="image-viewer" class="image-viewer">

            <button
                type="button"
                class="image-viewer-close"
                aria-label="Fermer l'image"
            >
                ×
            </button>

            <img
                src=""
                alt=""
                id="image-viewer-img"
                class="image-viewer-img"
            >

        </div>
        {% for article in articleList %}
            <div
                id="boutique-modal-{{ article.id }}"
                class="boutique-modal"
                aria-hidden="true"
                role="dialog"
                aria-modal="true"
                aria-labelledby="boutique-modal-title-{{ article.id }}"
            >
                <div class="boutique-modal-content">
                    <button
                        type="button"
                        class="boutique-modal-close"
                        aria-label="Fermer la fenêtre"
                    >
                        &times;
                    </button>

                    <h2 id="boutique-modal-title-{{ article.id }}">
                        Information
                    </h2>

                    <img
                        src="{{ asset('images/about/bien-choisir-son-nichoir.png') }}"
                        alt="Guide d'information"
                        class="boutique-modal-image"
                        loading="lazy"
                    >
                </div>
            </div>
        {% endfor %}
    </section>

{% endblock %}
