{% extends 'base.html.twig' %}

{% block body %}

    <h1>Mon panier</h1>

    {% for item in cart %}
        <div>
            <img
                src="{{ asset('images/shop/' ~ item.article.image) }}"
                alt="{{ item.article.name }}"
                width="150"
            >
            <p>{{ item.article.name }}</p>
            <p>Prix : {{ item.article.price }} €</p>

            <form method="post" action="{{ path('cart_update', { index: item.index }) }}">
                <label>
                    Quantité
                    <input
                        type="number"
                        name="quantity"
                        value="{{ item.quantity }}"
                        min="1"
                        required
                    >
                </label>

                <label>
                    <input
                        type="radio"
                        name="diameter"
                        value="28"
                        {% if item.diameter == 28 %}checked{% endif %}
                        required
                    >
                    28 mm
                </label>

                <label>
                    <input
                        type="radio"
                        name="diameter"
                        value="32"
                        {% if item.diameter == 32 %}checked{% endif %}
                    >
                    32 mm
                </label>

                <button type="submit">
                    Modifier
                </button>
            </form>
            <p>
                Total article :
                {{ item.lineTotal|number_format(2, ',', ' ') }} €
            </p>
            <form method="post" action="{{ path('cart_remove', { index: item.index }) }}">
                <button type="submit">
                    Supprimer
                </button>
            </form>
        </div>
    {% else %}
        <p>Votre panier est vide.</p>
    {% endfor %}
    {% if cart is not empty %}
        <hr>

        <h3>
            Total panier :
            {{ totalCart|number_format(2, ',', ' ') }} €
        </h3>

        <form method="post" action="{{ path('pre_order_validate') }}">
            <button type="submit">
                Valider la précommande
            </button>
        </form>
    {% endif %}

{% endblock %}
