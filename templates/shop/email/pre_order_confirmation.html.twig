{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Précommande reçue
{% endblock %}

{% block email_header %}
    <h1>Précommande reçue</h1>
    <p>SOS Faons Bretagne</p>
{% endblock %}

{% block email_content %}

    <p>
        Bonjour {{ preOrder.user.firstname }} {{ preOrder.user.lastname }},
    </p>

    <p>
        Nous avons bien reçu votre précommande.
        Elle va être vérifiée par l'équipe de <strong>SOS Faons Bretagne</strong>.
    </p>

    <div class="email-box">
        Vous recevrez un nouvel email avec le lien de paiement dès que votre précommande aura été validée.
    </div>

    <h2>Détail de la précommande</h2>

    <table class="email-table">
        <thead>
        <tr>
            <th>Article</th>
            <th>Diamètre</th>
            <th>Qté</th>
            <th>Prix</th>
            <th>Total</th>
        </tr>
        </thead>

        <tbody>
        {% for item in preOrder.preOrderItems %}
            <tr>
                <td>{{ item.article.name }}</td>
                <td>
                    {% if item.diameter %}
                        {{ item.diameter.value }} mm
                    {% else %}
                        Aucun
                    {% endif %}
                </td>
                <td>{{ item.quantity }}</td>
                <td>{{ item.unitPrice }} €</td>
                <td>{{ item.totalPrice }} €</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <p>
        <strong>Date de précommande :</strong><br>
        {{ preOrder.preOrderDate|date('d/m/Y') }}
    </p>

    <p>
        <strong>Total :</strong><br>
        <span class="email-amount">
            {{ preOrder.totalAmount }} €
        </span>
    </p>

    <p>
        Merci pour votre soutien et votre confiance.
    </p>

    <p>
        L'équipe <strong>SOS Faons Bretagne</strong>
    </p>

{% endblock %}

{% block email_footer %}
    Cet email a été généré automatiquement suite à l'enregistrement de votre précommande.<br>
    SOS Faons Bretagne — email@sosfaonsbretagne.fr
{% endblock %}
