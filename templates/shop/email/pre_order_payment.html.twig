{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Précommande validée
{% endblock %}

{% block email_header %}
    <h1>Précommande validée</h1>
    <p>SOS Faons Bretagne</p>
{% endblock %}

{% block email_content %}

    <p>
        Bonjour {{ preOrder.user.firstname }} {{ preOrder.user.lastname }},
    </p>

    <p>
        Votre précommande a été validée par <strong>SOS Faons Bretagne</strong>.
    </p>

    <div class="email-box">
        Vous pouvez maintenant procéder au paiement de votre précommande.
    </div>

    <h2>Récapitulatif de votre précommande</h2>

    <table class="email-table">
        <thead>
        <tr>
            <th>Article</th>
            <th>Diamètre</th>
            <th>Quantité</th>
            <th>Prix unitaire</th>
            <th>Total</th>
        </tr>
        </thead>

        <tbody>
        {% for item in preOrder.preOrderItems %}
            <tr>
                <td>
                    <strong>{{ item.article.name }}</strong>
                </td>

                <td>
                    {% if item.diameter %}
                        {{ item.diameter.value }} mm
                    {% else %}
                        Aucun
                    {% endif %}
                </td>

                <td>
                    {{ item.quantity }}
                </td>

                <td>
                    {{ item.unitPrice }} €
                </td>

                <td>
                    {{ item.totalPrice }} €
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="email-box">
        <strong>Total commande :</strong><br>
        <span class="email-amount">
            {{ preOrder.totalAmount }} €
        </span>
    </div>

    <p>
        <a href="{{ url('pre_order_pay', { id: preOrder.id }) }}" class="email-button">
            Payer ma précommande
        </a>
    </p>

    <p>
        Merci pour votre soutien.
    </p>

    <p>
        L'équipe <strong>SOS Faons Bretagne</strong>
    </p>

{% endblock %}

{% block email_footer %}
    Cet email a été généré automatiquement suite à la validation de votre précommande.<br>
    SOS Faons Bretagne — email@sosfaonsbretagne.fr
{% endblock %}
