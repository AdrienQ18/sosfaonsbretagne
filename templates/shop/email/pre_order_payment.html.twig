<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Précommande validée</title>
</head>
<body>

<h1>Votre précommande a été validée</h1>

<p>
    Bonjour {{ preOrder.user.firstname }} {{ preOrder.user.lastname }},
</p>

<p>
    Votre précommande a été validée par SOS Faons Bretagne.
</p>

<p>
    Vous pouvez maintenant procéder au paiement.
</p>

<hr>

<h2>Récapitulatif de votre précommande</h2>

{% for item in preOrder.preOrderItems %}

    <div style="margin-bottom: 20px;">

        <img
            src="{{ email.image('@images/shop/' ~ item.article.image) }}"
            alt="{{ item.article.name }}"
            width="150"
        >

        <p>
            <strong>{{ item.article.name }}</strong>
        </p>

        <p>
            Diamètre :
            <td>
                {% if item.diameter %}
                    {{ item.diameter.value }} mm
                {% else %}
                    Aucun
                {% endif %}
            </td>        </p>

        <p>
            Quantité :
            {{ item.quantity }}
        </p>

        <p>
            Prix unitaire :
            {{ item.unitPrice }} €
        </p>

        <p>
            Total :
            {{ item.totalPrice }} €
        </p>

    </div>

    <hr>

{% endfor %}

<h2>
    Total commande :
    {{ preOrder.totalAmount }} €
</h2>

<p>
    <a
        href="{{ url('pre_order_pay', { id: preOrder.id }) }}"
        style="
            background-color:#4CAF50;
            color:white;
            padding:12px 20px;
            text-decoration:none;
            border-radius:5px;
            display:inline-block;
        "
    >
        Payer ma précommande
    </a>
</p>

<p>
    Merci pour votre soutien ❤️
</p>

</body>
</html>
