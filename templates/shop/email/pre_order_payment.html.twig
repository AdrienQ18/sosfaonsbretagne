{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Précommande validée
{% endblock %}

{% block email_header %} <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3;">
    Précommande validée </h1>

    <p style="margin:8px 0 0 0; color:#ffffff;">
        SOS Faons Bretagne
    </p>

{% endblock %}

{% block email_content %}

    <p style="margin:0 0 18px 0;">
        Bonjour {{ preOrder.user.firstname }} {{ preOrder.user.lastname }},
    </p>

    <p style="margin:0 0 18px 0;">
        Votre précommande a été validée par <strong>SOS Faons Bretagne</strong>.
    </p>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:20px 0 24px 0;">
        <tr>
            <td style="background-color:#f4efe8; border-left:4px solid #6e8e64; padding:16px; color:#2b2b2b; line-height:1.6;">
                Vous pouvez maintenant procéder au paiement sécurisé de votre précommande.
            </td>
        </tr>
    </table>

    <h2 style="margin:0 0 16px 0; color:#1b4a3a; font-size:20px; font-weight:bold;">
        Récapitulatif de votre précommande
    </h2>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="border-collapse:collapse; margin-bottom:24px;">

        <thead>
        <tr>
            <th style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; color:#1b4a3a; text-align:left;">
                Article
            </th>

            <th style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; color:#1b4a3a; text-align:center;">
                Diamètre
            </th>

            <th style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; color:#1b4a3a; text-align:center;">
                Quantité
            </th>

            <th style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; color:#1b4a3a; text-align:right;">
                Prix unitaire
            </th>

            <th style="background:#f4efe8; border:1px solid #ddd5cc; padding:12px; color:#1b4a3a; text-align:right;">
                Total
            </th>
        </tr>
        </thead>

        <tbody>
        {% for item in preOrder.preOrderItems %}
            <tr>
                <td style="border:1px solid #ddd5cc; padding:12px;">
                    <strong>{{ item.article.name }}</strong>
                </td>

                <td style="border:1px solid #ddd5cc; padding:12px; text-align:center;">
                    {% if item.diameter %}
                        {{ item.diameter.value }} mm
                    {% else %}
                        —
                    {% endif %}
                </td>

                <td style="border:1px solid #ddd5cc; padding:12px; text-align:center;">
                    {{ item.quantity }}
                </td>

                <td style="border:1px solid #ddd5cc; padding:12px; text-align:right;">
                    {{ item.unitPrice|number_format(2, ',', ' ') }} €
                </td>

                <td style="border:1px solid #ddd5cc; padding:12px; text-align:right;">
                    {{ item.totalPrice|number_format(2, ',', ' ') }} €
                </td>
            </tr>
        {% endfor %}
        </tbody>

    </table>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin-bottom:24px;">
        <tr>
            <td style="background-color:#f4efe8; border-left:4px solid #6e8e64; padding:18px; color:#2b2b2b; line-height:1.6;">

                <strong style="display:block; margin-bottom:8px; color:#1b4a3a;">
                    Total de la commande
                </strong>

                <span style="color:#1b4a3a; font-size:24px; font-weight:bold;">
                {{ preOrder.totalAmount|number_format(2, ',', ' ') }} €
            </span>

            </td>
        </tr>
    </table>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 0 28px 0;">
        <tr>
            <td align="center">
                <table cellpadding="0" cellspacing="0" border="0" role="presentation">
                    <tr>
                        <td align="center" bgcolor="#1b4a3a" style="border-radius:8px;">
                            <a
                                href="{{ url('pre_order_pay', { id: preOrder.id }) }}"
                                style="display:inline-block; padding:14px 28px; color:#ffffff; text-decoration:none; font-weight:bold; font-size:14px;"
                            >
                                Payer ma précommande
                            </a>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <p style="margin:0 0 18px 0;">
        Merci pour votre soutien.
    </p>

    <p style="margin:0;">
        L'équipe <strong>SOS Faons Bretagne</strong>
    </p>

{% endblock %}

{% block email_footer %}
    Cet email a été généré automatiquement suite à la validation de votre précommande.<br>
    SOS Faons Bretagne — [contact@sosfaonsbretagne.fr](mailto:contact@sosfaonsbretagne.fr)
{% endblock %}
