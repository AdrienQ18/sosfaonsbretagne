{% extends 'emails/_base_email.html.twig' %}

{% block email_title %}
    Précommande validée
{% endblock %}

{% block email_header %}
    <h1 style="margin:0; color:#ffffff; font-size:26px; line-height:1.3;">
        Précommande validée
    </h1>

    <p style="margin:8px 0 0 0; color:#ffffff;">
        SOS Faons Bretagne
    </p>
{% endblock %}

{% block email_content %}

    <p style="margin:0 0 18px 0;">
        Bonjour {{ preOrder.user.firstname }} {{ preOrder.user.lastname }},
    </p>

    <p style="margin:0 0 18px 0;">
        Votre précommande a été validée par
        <strong>SOS Faons Bretagne</strong>.
    </p>

    <div
        style="
            background-color:#f4efe8;
            border-left:4px solid #6e8e64;
            padding:16px;
            margin:20px 0;
            color:#2b2b2b;
            line-height:1.6;
        "
    >
        Vous pouvez maintenant procéder au paiement de votre précommande.
    </div>

    <h2
        style="
            color:#1b4a3a;
            font-size:20px;
            margin:0 0 16px 0;
        "
    >
        Récapitulatif de votre précommande
    </h2>

    <table
        width="100%"
        cellpadding="0"
        cellspacing="0"
        border="0"
        style="
            border-collapse:collapse;
            margin-bottom:24px;
        "
    >

        <thead>
        <tr>

            <th
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    color:#1b4a3a;
                    text-align:left;
                "
            >
                Article
            </th>

            <th
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    color:#1b4a3a;
                    text-align:left;
                "
            >
                Diamètre
            </th>

            <th
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    color:#1b4a3a;
                    text-align:center;
                "
            >
                Quantité
            </th>

            <th
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    color:#1b4a3a;
                    text-align:right;
                "
            >
                Prix unitaire
            </th>

            <th
                style="
                    background:#f4efe8;
                    border:1px solid #ddd5cc;
                    padding:12px;
                    color:#1b4a3a;
                    text-align:right;
                "
            >
                Total
            </th>

        </tr>
        </thead>

        <tbody>

        {% for item in preOrder.preOrderItems %}

            <tr>

                <td
                    style="
                        border:1px solid #ddd5cc;
                        padding:12px;
                    "
                >
                    <strong>{{ item.article.name }}</strong>
                </td>

                <td
                    style="
                        border:1px solid #ddd5cc;
                        padding:12px;
                    "
                >
                    {% if item.diameter %}
                        {{ item.diameter.value }} mm
                    {% else %}
                        Aucun
                    {% endif %}
                </td>

                <td
                    style="
                        border:1px solid #ddd5cc;
                        padding:12px;
                        text-align:center;
                    "
                >
                    {{ item.quantity }}
                </td>

                <td
                    style="
                        border:1px solid #ddd5cc;
                        padding:12px;
                        text-align:right;
                    "
                >
                    {{ item.unitPrice|number_format(2, ',', ' ') }} €
                </td>

                <td
                    style="
                        border:1px solid #ddd5cc;
                        padding:12px;
                        text-align:right;
                    "
                >
                    {{ item.totalPrice|number_format(2, ',', ' ') }} €
                </td>

            </tr>

        {% endfor %}

        </tbody>

    </table>

    <div
        style="
            background-color:#f4efe8;
            border-left:4px solid #6e8e64;
            padding:18px;
            margin-bottom:24px;
        "
    >

        <strong
            style="
                display:block;
                margin-bottom:8px;
                color:#1b4a3a;
            "
        >
            Total de la commande
        </strong>

        <span
            style="
                color:#1b4a3a;
                font-size:24px;
                font-weight:bold;
            "
        >
            {{ preOrder.totalAmount|number_format(2, ',', ' ') }} €
        </span>

    </div>

    <p style="text-align:center; margin:0 0 28px 0;">

        <a
            href="{{ url('pre_order_pay', { id: preOrder.id }) }}"
            style="
                display:inline-block;
                background-color:#1b4a3a;
                color:#ffffff;
                padding:14px 28px;
                text-decoration:none;
                font-weight:bold;
                border-radius:8px;
            "
        >
            Payer ma précommande
        </a>

    </p>

    <p style="margin:0 0 18px 0;">
        Merci pour votre soutien.
    </p>

    <p style="margin:0;">
        L'équipe <strong>SOS Faons Bretagne</strong>
    </p>

{% endblock %}

{% block email_footer %}
    Cet email a été généré automatiquement suite à la validation de votre précommande.<br>
    SOS Faons Bretagne — contact@sosfaonsbretagne.fr
{% endblock %}
