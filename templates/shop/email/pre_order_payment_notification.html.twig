<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">

    <style>
        body {
            margin: 0;
            padding: 0;
            background: #f4f6f5;
            font-family: Arial, sans-serif;
            color: #1f2d24;
        }

        .container {
            width: 600px;
            margin: 30px auto;
            background: white;
            border-radius: 12px;
            overflow: hidden;
        }

        .header {
            background: #2f5d3a;
            color: white;
            padding: 24px;
            text-align: center;
        }

        .content {
            padding: 28px;
        }

        .success {
            background: #eef3f0;
            padding: 16px;
            border-left: 4px solid #2f5d3a;
            margin-bottom: 20px;
        }

        .amount {
            font-size: 20px;
            font-weight: bold;
            color: #2f5d3a;
        }

        .footer {
            background: #eef3f0;
            padding: 20px;
            font-size: 12px;
        }
    </style>

    <title>Paiement précommande confirmé</title>
</head>

<body>

<div class="container">

    <div class="header">
        <h1>Paiement confirmé</h1>
    </div>

    <div class="content">

        <div class="success">
            Le paiement d’une précommande vient d’être confirmé via HelloAsso.
        </div>

        <p>
            <strong>Client :</strong><br>
            {{ preOrder.user.firstname }}
            {{ preOrder.user.lastname }}
        </p>

        <p>
            <strong>Email :</strong><br>
            {{ preOrder.user.email }}
        </p>

        <p>
            <strong>Précommande :</strong><br>
            #{{ preOrder.id }}
        </p>

        <p>
            <strong>Date paiement :</strong><br>
            {{ preOrder.paidAt|date('d/m/Y H:i') }}
        </p>

        <p class="amount">
            Montant payé : {{ preOrder.totalAmount }} €
        </p>

    </div>

    <div class="footer">
        Notification automatique SOS Faons Bretagne
    </div>

</div>

</body>
</html>
