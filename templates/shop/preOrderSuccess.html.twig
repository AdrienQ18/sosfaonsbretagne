{% extends 'base.html.twig' %}

{% block title %}
    Confirmation de précommande | SOS Faons Bretagne
{% endblock %}

{% block meta_description %}
    Confirmation privée de paiement pour une précommande SOS Faons Bretagne.
{% endblock %}

{% block robots %}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block canonical %}{% endblock %}

{% block body %}

    <h1>Merci pour votre paiement</h1>

    <p>
        Votre paiement est en cours de confirmation.
    </p>

    <p>
        Précommande n°{{ preOrder.id }}
    </p>

    {% if preOrder.status.value == 'payee' %}
        <p>
            Paiement confirmé ✅
        </p>
    {% else %}
        <p>
            Confirmation du paiement en cours...
        </p>
    {% endif %}

    <p>
        Vous recevrez une confirmation par email dès que le paiement sera validé.
    </p>

{% endblock %}
